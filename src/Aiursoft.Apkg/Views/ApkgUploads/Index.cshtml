@model Aiursoft.Apkg.Models.ApkgUploadsViewModels.ApkgUploadsIndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>My Packages (APKG)</h3>
    </div>
    <div class="col-auto ms-auto">
        <a asp-action="Upload" class="btn btn-primary">
            <i class="align-middle me-1" data-lucide="upload"></i>
            Upload New Package
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (!Model.Uploads.Any())
        {
            <p class="text-muted mb-0">No APKG uploads yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Package</th>
                            <th>Version</th>
                            <th>Component</th>
                            <th>Status</th>
                            <th>Uploaded</th>
                            @if (Model.IsAdmin)
                            {
                                <th>Uploader</th>
                            }
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var upload in Model.Uploads)
                        {
                            var statusText = upload.IsListed
                                ? (upload.IsPublished ? "Published" : "Pending")
                                : "Unlisted";
                            var statusClass = upload.IsListed
                                ? (upload.IsPublished ? "bg-success" : "bg-warning text-dark")
                                : "bg-secondary";
                            <tr>
                                <td><strong>@upload.Package</strong></td>
                                <td><span class="badge bg-info">@upload.Version</span></td>
                                <td><span class="badge bg-dark">@upload.Component</span></td>
                                <td><span class="badge @statusClass">@statusText</span></td>
                                <td><small class="text-muted">@upload.UploadedAt.ToString("yyyy/M/d HH:mm")</small></td>
                                @if (Model.IsAdmin)
                                {
                                    <td><small>@(upload.UploadedByUser?.UserName ?? "—")</small></td>
                                }
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@upload.Id" class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="align-middle" data-lucide="eye"></i>
                                        </a>
                                        @if (upload.IsListed)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#unlistUpload-@upload.Id" title="Unlist">
                                                <i class="align-middle" data-lucide="archive-x"></i>
                                            </button>
                                        }
                                        @if (Model.IsAdmin)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteUpload-@upload.Id" title="Delete">
                                                <i class="align-middle" data-lucide="trash-2"></i>
                                            </button>
                                        }
                                    </div>

                                    @if (upload.IsListed)
                                    {
                                        <div class="modal fade" id="unlistUpload-@upload.Id" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog">
                                                <div class="modal-content text-start">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Confirm Unlist</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        Unlist <strong>@upload.Package (@upload.Version)</strong>? Generated packages will be disabled.
                                                    </div>
                                                    <div class="modal-footer">
                                                        <form method="post" asp-action="Unlist" asp-route-id="@upload.Id">
                                                            @Html.AntiForgeryToken()
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-warning">Unlist</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @if (Model.IsAdmin)
                                    {
                                        <div class="modal fade" id="deleteUpload-@upload.Id" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog">
                                                <div class="modal-content text-start">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Confirm Delete</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        Permanently delete <strong>@upload.Package (@upload.Version)</strong> and all generated LocalPackages?
                                                    </div>
                                                    <div class="modal-footer">
                                                        <form method="post" asp-action="Delete" asp-route-id="@upload.Id">
                                                            @Html.AntiForgeryToken()
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-danger">Delete</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
