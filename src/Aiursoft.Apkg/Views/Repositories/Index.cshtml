@model Aiursoft.Apkg.Models.MirrorsViewModels.RepoIndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Public Repositories"]</h3>
    </div>
    <div class="col-auto ms-auto text-end">
        <a asp-action="Create" class="btn btn-primary">
            <i class="align-middle" data-lucide="plus"></i> @Localizer["Create New Repository"]
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
            <tr>
                <th>@Localizer["Distro"]</th>
                <th>@Localizer["Name"]</th>
                <th>@Localizer["Suite"]</th>
                <th>@Localizer["Certificate"]</th>
                <th>@Localizer["Live Bucket"]</th>
                <th>@Localizer["Secondary Bucket"]</th>
                <th>@Localizer["Signature"]</th>
                <th>@Localizer["Total Packages"]</th>
                <th class="text-end">@Localizer["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Repositories)
            {
                <tr>
                    <td><span class="badge badge-subtle-primary">@item.Distro</span></td>
                    <td><strong>@item.Name</strong></td>
                    <td><span class="badge bg-primary">@item.Suite</span></td>
                    <td>
                        @if (item.Certificate != null)
                        {
                            <span class="badge bg-success" title="@item.Certificate.Fingerprint">@item.Certificate.FriendlyName</span>
                        }
                    </td>
                    <td>
                        @if (item.PrimaryBucketId != null)
                        {
                            <a asp-controller="Buckets" asp-action="Packages" asp-route-id="@item.PrimaryBucketId" class="badge bg-success text-decoration-none">#@item.PrimaryBucketId</a>
                        }
                    </td>
                    <td>
                        @if (item.SecondaryBucketId != null)
                        {
                            <a asp-controller="Buckets" asp-action="Packages" asp-route-id="@item.SecondaryBucketId" class="badge bg-warning text-decoration-none">#@item.SecondaryBucketId</a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        @if (item.PrimaryBucket?.SignedAt != null)
                        {
                            <span class="badge bg-success" title="Signed at @item.PrimaryBucket.SignedAt.Value.ToString("u")">
                                <i class="align-middle" data-lucide="shield-check"></i>
                                @Localizer["Signed at"] @item.PrimaryBucket.SignedAt.Value.ToString("yyyy-MM-dd HH:mm") UTC
                            </span>
                        }
                        else if (item.PrimaryBucket?.InReleaseContent != null)
                        {
                            <span class="badge bg-success">
                                <i class="align-middle" data-lucide="shield-check"></i>
                                @Localizer["Signed"]
                            </span>
                        }
                        else if (item.PrimaryBucketId != null)
                        {
                            <span class="badge bg-secondary">
                                <i class="align-middle" data-lucide="shield-off"></i>
                                @Localizer["No Certificate"]
                            </span>
                        }
                    </td>
                    <td>
                        @(item.PrimaryBucketId.HasValue ? Model.PackageCounts.GetValueOrDefault(item.PrimaryBucketId.Value, 0) : 0)
                    </td>
                    <td class="text-end">
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="align-middle" data-lucide="edit"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                <i class="align-middle" data-lucide="info"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteRepo-@item.Id">
                                <i class="align-middle" data-lucide="trash-2"></i>
                            </button>
                        </div>

                        <div class="modal fade" id="deleteRepo-@item.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Confirm Delete</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        Are you sure you want to delete repository <strong>@item.Name</strong>?
                                    </div>
                                    <div class="modal-footer">
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-danger">Delete Repository</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
