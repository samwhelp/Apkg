@model Aiursoft.Apkg.Models.MirrorsViewModels.RepoDetailsViewModel
@using Aiursoft.Apkg.Authorization
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@{
    var canManage = (await AuthorizationService.AuthorizeAsync(User, AppPermissionNames.CanManageRepositories)).Succeeded;
}

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>@Localizer["Repository Details"] - @Model.Repo.Name</h3>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header"><h5 class="card-title mb-0">@Localizer["Information"]</h5></div>
            <div class="card-body">
                <p><strong>@Localizer["Distro"]:</strong> @Model.Repo.Distro</p>
                <p><strong>@Localizer["Suite"]:</strong> @Model.Repo.Suite</p>
                <p><strong>@Localizer["Mirror Source"]:</strong> @(Model.Repo.Mirror?.Suite ?? "None")</p>
                @if (canManage)
                {
                    <p><strong>@Localizer["Live Bucket"]:</strong> 
                    @if (Model.Repo.PrimaryBucketId != null)
                    {
                        <a asp-controller="Buckets" asp-action="Packages" asp-route-id="@Model.Repo.PrimaryBucketId" class="badge bg-success text-decoration-none">#@Model.Repo.PrimaryBucketId</a>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                    </p>
                }
                <p><strong>@Localizer["Certificate"]:</strong> @(Model.Repo.Certificate?.FriendlyName ?? "None")</p>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header"><h5 class="card-title mb-0">@Localizer["Client Configuration Guide"]</h5></div>
            <div class="card-body">
                @if (Model.Repo.EnableGpgSign && Model.Repo.Certificate != null)
                {
                    <h6>@Localizer["One-line Setup:"]</h6>
                    <div class="bg-dark text-white p-3 rounded mb-4 position-relative">
                        <button class="btn btn-sm btn-outline-light position-absolute top-0 end-0 m-2" onclick="copyToClipboard(this)" title="@Localizer["Copy to clipboard"]">
                            <i class="align-middle" data-lucide="copy" style="width:14px;height:14px;"></i>
                        </button>
                        <pre class="mb-0" style="white-space: pre-wrap; word-break: break-all;"><code>sudo mkdir -p /usr/share/keyrings && \
curl -sL @(Context.Request.Scheme)://@(Context.Request.Host)/artifacts/certs/@Model.Repo.Certificate.Name | gpg --dearmor | sudo tee /usr/share/keyrings/@(Model.Repo.Certificate.Name)-archive-keyring.gpg > /dev/null && \
echo "Types: deb
URIs: @(Context.Request.Scheme)://@(Context.Request.Host)/artifacts/@Model.Repo.Distro/
Suites: @Model.Repo.Suite
Components: @((string.IsNullOrWhiteSpace(Model.Repo.Components) ? "main" : Model.Repo.Components).Replace(",", " "))
Architectures: @Model.Repo.Architecture
Signed-By: /usr/share/keyrings/@(Model.Repo.Certificate.Name)-archive-keyring.gpg" | sudo tee /etc/apt/sources.list.d/apkg-@(Model.Repo.Id).sources && \
sudo apt update</code></pre>
                    </div>

                    <div class="alert alert-info py-2">
                        <i class="align-middle me-1" data-lucide="info" style="width:14px;height:14px;"></i>
                        <small>@Localizer["This uses the modern DEB822 format and a scoped keyring for maximum security and reliability."]</small>
                    </div>
                }
                else
                {
                    <h6>@Localizer["One-line Setup (Unsigned):"]</h6>
                    <div class="bg-dark text-white p-3 rounded mb-4 position-relative">
                        <button class="btn btn-sm btn-outline-light position-absolute top-0 end-0 m-2" onclick="copyToClipboard(this)" title="@Localizer["Copy to clipboard"]">
                            <i class="align-middle" data-lucide="copy" style="width:14px;height:14px;"></i>
                        </button>
                        <pre class="mb-0" style="white-space: pre-wrap; word-break: break-all;"><code>echo "Types: deb
URIs: @(Context.Request.Scheme)://@(Context.Request.Host)/artifacts/@Model.Repo.Distro/
Suites: @Model.Repo.Suite
Components: @((string.IsNullOrWhiteSpace(Model.Repo.Components) ? "main" : Model.Repo.Components).Replace(",", " "))
Architectures: @Model.Repo.Architecture
Trusted: yes" | sudo tee /etc/apt/sources.list.d/apkg-@(Model.Repo.Id).sources && \
sudo apt update</code></pre>
                    </div>

                    <div class="alert alert-warning py-2">
                        <i class="align-middle me-1" data-lucide="alert-triangle" style="width:14px;height:14px;"></i>
                        <small>@Localizer["This repository is not signed. We are using 'Trusted: yes' to bypass security checks. Use with caution!"]</small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Packages" asp-route-id="@Model.Repo.Id" class="btn btn-primary">
        <i class="align-middle me-1" data-lucide="package-search"></i> @Localizer["Browse Packages"]
    </a>
    
    @if (canManage && Model.Repo.PrimaryBucketId != null)
    {
        <form asp-action="CheckDependencies" asp-route-id="@Model.Repo.Id" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-info">
                <i class="align-middle me-1" data-lucide="check-circle"></i> @Localizer["Check Dependencies"]
            </button>
        </form>
    }
    
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Back to List"]</a>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        function copyToClipboard(btn) {
            const pre = btn.nextElementSibling;
            const code = pre.querySelector('code');
            const text = code.innerText;
            navigator.clipboard.writeText(text).then(() => {
                const icon = btn.querySelector('i');
                const originalData = icon.getAttribute('data-lucide');
                icon.setAttribute('data-lucide', 'check');
                lucide.createIcons();
                setTimeout(() => {
                    icon.setAttribute('data-lucide', originalData);
                    lucide.createIcons();
                }, 2000);
            });
        }
    </script>
}
