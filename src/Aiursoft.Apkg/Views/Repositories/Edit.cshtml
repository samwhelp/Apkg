@model Aiursoft.Apkg.Models.MirrorsViewModels.RepoEditViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>@(Model.Id == 0 ? Localizer["Create New Repository"] : Localizer["Edit Repository"])</h3>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post">
            @if (Model.Id != 0)
            {
                <input type="hidden" asp-for="Id" />
            }

            <div class="mb-3">
                <label asp-for="Distro" class="form-label"></label>
                <input asp-for="Distro" class="form-control" placeholder="ubuntu" required />
                <div class="form-text">The URL prefix for this repository (e.g. 'ubuntu').</div>
                <span asp-validation-for="Distro" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="my-custom-repo" required />
                    <div class="form-text">The internal identifier and part of the URL path.</div>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Suite" class="form-label"></label>
                    <input asp-for="Suite" class="form-control" placeholder="stable" required />
                    <div class="form-text">The APT suite name (e.g. jammy, stable).</div>
                    <span asp-validation-for="Suite" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Components" class="form-label"></label>
                    <input asp-for="Components" class="form-control" placeholder="main,universe" required />
                    <div class="form-text">Comma-separated components.</div>
                    <span asp-validation-for="Components" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Architecture" class="form-label"></label>
                    <input asp-for="Architecture" class="form-control" placeholder="amd64" required />
                    <div class="form-text">Comma-separated architectures.</div>
                    <span asp-validation-for="Architecture" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="MirrorId" class="form-label"></label>
                <select asp-for="MirrorId" asp-items="Model.AvailableMirrors" class="form-select">
                    <option value="">-- None (Standalone) --</option>
                </select>
                <div class="form-text">If linked to a mirror, this repository will serve packages from that upstream source.</div>
            </div>

            <div class="mb-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" asp-for="EnableGpgSign" id="enableGpgSign">
                    <label class="form-check-label" asp-for="EnableGpgSign"></label>
                </div>
                <div class="form-text">Automatically sign the Release files of this repository.</div>
            </div>

            <div class="mb-3" id="certSelection">
                <label asp-for="CertificateId" class="form-label"></label>
                <select asp-for="CertificateId" asp-items="Model.AvailableCertificates" class="form-select" id="certificateIdSelect"></select>
                <div class="form-text">The GPG key used to sign the Release files of this repository.</div>
            </div>

            <hr />
            <button type="submit" class="btn btn-primary">@Localizer["Save Repository"]</button>
            <a asp-action="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </form>
    </div>
</div>

@section scripts {
    <script>
        const enableGpgSign = document.getElementById('enableGpgSign');
        const certSelection = document.getElementById('certSelection');
        const certificateIdSelect = document.getElementById('certificateIdSelect');

        function updateCertVisibility() {
            if (enableGpgSign.checked) {
                certSelection.style.display = 'block';
                certificateIdSelect.required = true;
            } else {
                certSelection.style.display = 'none';
                certificateIdSelect.required = false;
            }
        }

        enableGpgSign.addEventListener('change', updateCertVisibility);
        updateCertVisibility();
    </script>
}
