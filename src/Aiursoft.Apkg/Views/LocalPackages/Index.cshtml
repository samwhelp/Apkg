@using Aiursoft.Apkg.Models.LocalPackagesViewModels
@model Aiursoft.Apkg.Models.LocalPackagesViewModels.LocalPackagesIndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>@Localizer["My Packages"]</h3>
    </div>
    <div class="col-auto ms-auto">
        <a asp-action="Upload" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-lucide="upload" class="lucide lucide-upload align-middle me-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" x2="12" y1="3" y2="15"></line></svg>
            @Localizer["Upload deb package"]
        </a>
    </div>
</div>

<div class="row">
    <div class="col-xl-10">
        <div class="card h-100">
    <div class="card-body">
        @if (!Model.Packages.Any())
        {
            <p class="text-muted">@Localizer["No packages uploaded yet."]</p>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>@Localizer["Package"]</th>
                        <th>@Localizer["Version"]</th>
                        <th>@Localizer["Architecture"]</th>
                        <th>@Localizer["Repository"]</th>
                        @if (Model.IsAdmin)
                        {
                            <th>@Localizer["Uploader"]</th>
                        }
                        <th>
                            @Localizer["Sync Status"]
                            <i data-lucide="circle-help" style="width:14px;height:14px;vertical-align:middle;margin-left:3px;cursor:help;"
                               data-bs-toggle="tooltip" data-bs-placement="top"
                               data-bs-title="@Localizer["The current progress of this package being merged and signed into the live repository. The sync job runs every 20 minutes, followed by a sign job every 5 minutes."] @Localizer["A live package is available for APT clients."] "></i>
                        </th>
                        <th>@Localizer["Uploaded"]</th>
                        <th class="text-end">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var info in Model.Packages)
                    {
                        var pkg = info.Package;
                        <tr>
                            <td><strong>@pkg.Package</strong></td>
                            <td><span class="badge bg-info">@pkg.Version</span></td>
                            <td><span class="badge bg-dark">@pkg.Architecture</span></td>
                            <td><small>@(pkg.Repository?.Suite ?? "—")</small></td>
                            @if (Model.IsAdmin)
                            {
                                <td><small>@(pkg.UploadedByUser?.UserName ?? "—")</small></td>
                            }
                            <td>
                                @switch (info.Status)
                                {
                                    case LocalPackageStatus.Live:
                                        <span class="badge bg-success" title="@info.StatusMessage">
                                            <i class="align-middle me-1" data-lucide="check-circle" style="width:12px; height:12px;"></i> @Localizer["Live"]
                                        </span>
                                        break;
                                    case LocalPackageStatus.StagedForSigning:
                                        <span class="badge bg-info" title="@info.StatusMessage">
                                            <i class="align-middle me-1" data-lucide="clock" style="width:12px; height:12px;"></i> @Localizer["Staged (Waiting for Sign)"]
                                        </span>
                                        break;
                                    case LocalPackageStatus.PendingSync:
                                        <span class="badge bg-warning text-dark" title="@info.StatusMessage">
                                            <i class="align-middle me-1" data-lucide="refresh-cw" style="width:12px; height:12px;"></i> @Localizer["Pending Sync"]
                                        </span>
                                        break;
                                    case LocalPackageStatus.Superseded:
                                        <span class="badge bg-secondary" title="@info.StatusMessage">
                                            <i class="align-middle me-1" data-lucide="archive" style="width:12px; height:12px;"></i> @Localizer["Superseded"]
                                        </span>
                                        break;
                                    case LocalPackageStatus.Disabled:
                                        <span class="badge bg-secondary" title="@info.StatusMessage">
                                            <i class="align-middle me-1" data-lucide="slash" style="width:12px; height:12px;"></i> @Localizer["Disabled"]
                                        </span>
                                        break;
                                }
                            </td>
                            <td><small class="text-muted">@pkg.CreatedAt.ToString("yyyy/M/d HH:mm")</small></td>
                            <td class="text-end">
                                <div class="btn-group">
                                    @if (info.Status == LocalPackageStatus.Live && info.LivePackageId.HasValue)
                                    {
                                        <a asp-controller="Repositories" asp-action="PackageDetails" asp-route-id="@info.LivePackageId.Value" 
                                           class="btn btn-sm btn-outline-info" title="@Localizer["View Details & Install Instructions"]">
                                            <i class="align-middle" data-lucide="external-link"></i>
                                        </a>
                                    }
                                    <form method="post" asp-action="Toggle" asp-route-id="@pkg.Id">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(pkg.IsEnabled ? "btn-outline-warning" : "btn-outline-success")"
                                                title="@(pkg.IsEnabled ? Localizer["Disable: exclude from the Repository Sync index."].Value : Localizer["Enable: include in the next Repository Sync, overriding the upstream mirror version."].Value)">
                                            @if (pkg.IsEnabled)
                                            {
                                                <i class="align-middle" data-lucide="pause-circle"></i>
                                            }
                                            else
                                            {
                                                <i class="align-middle" data-lucide="play-circle"></i>
                                            }
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deletePackage-@pkg.Id">
                                        <i class="align-middle" data-lucide="trash-2"></i>
                                    </button>
                                </div>
                                <div class="modal fade" id="deletePackage-@pkg.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content text-start">
                                            <div class="modal-header">
                                                <h5 class="modal-title">@Localizer["Confirm Delete"]</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                @Localizer["Are you sure you want to delete"] <strong>@pkg.Package (@pkg.Version)</strong>?
                                            </div>
                                            <div class="modal-footer">
                                                <form method="post" asp-action="Delete" asp-route-id="@pkg.Id">
                                                    @Html.AntiForgeryToken()
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                                                    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
            </div>
        </div>
    </div>
    <div class="d-none d-xl-block col-xl-2">
        <div class="card border-primary">
            <div class="card-body">
                <div class="text-center mb-3">
                    <i data-lucide="folder-archive" style="width:48px;height:48px;"></i>
                </div>
                <h6 class="mb-2">@Localizer["What is a deb package?"]</h6>
                <p class="text-muted small mb-2">@Localizer["A .deb package is the standard Debian binary package format used by Debian, Ubuntu, and other APT-based Linux distributions. It contains compiled application binaries, metadata, and installation scripts."]</p>
                <p class="text-muted small mb-0"><strong>@Localizer["Tip:"]</strong> @Localizer["Each deb package maps to one repo+suite+arch combination. The Repository Sync job copies them into live buckets."]</p>
            </div>
        </div>
    </div>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
    </script>
}
