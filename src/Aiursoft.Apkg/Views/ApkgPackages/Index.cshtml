@model Aiursoft.Apkg.Models.ApkgPackagesViewModels.ApkgPackagesIndexViewModel
@using Aiursoft.Apkg.Models.ApkgPackagesViewModels

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>@Localizer["My Packages (APKG)"]</h3>
    </div>
    <div class="col-auto ms-auto">
        <a asp-action="Upload" class="btn btn-primary">
            <i class="align-middle me-1" data-lucide="upload"></i>
            @Localizer["Upload apkg mixed package"]
        </a>
    </div>
</div>

<div class="row">
    <div class="col-xl-10">
        <div class="card h-100">
    <div class="card-body">
        @if (!Model.Packages.Any())
        {
            <p class="text-muted mb-0">@Localizer["No APKG uploads yet."]</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["Package"]</th>
                            <th>@Localizer["Distro"]</th>
                            <th>@Localizer["Component"]</th>
                            <th>@Localizer["Published"]</th>
                            <th style="max-width: 200px;">@Localizer["Active Versions"]</th>
                            <th>@Localizer["Status"]</th>
                            <th>@Localizer["Next Version"]</th>
                            <th>@Localizer["Uploaded"]</th>
                            <th class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Packages)
                        {
                            var revision = item.DisplayRevision;
                            var syncStatus = item.SyncStatus;
                            var (statusText, statusClass) = syncStatus switch
                            {
                                UploadSyncStatus.Live       => ("Live",       "bg-success"),
                                UploadSyncStatus.Signing    => ("Signing",    "bg-info"),
                                UploadSyncStatus.Syncing    => ("Syncing",    "bg-info"),
                                UploadSyncStatus.Superseded => ("Superseded", "bg-secondary"),
                                UploadSyncStatus.Unlisted   => ("Unlisted",   "bg-secondary"),
                                UploadSyncStatus.Unlisting => ("Unlisting", "bg-warning text-dark"),
                                _                           => ("Syncing",    "bg-info"),
                            };

                            string publishBadgeClass;
                            if (item.TotalPackageCount == 0)
                                publishBadgeClass = "bg-secondary";
                            else if (item.PublishedCount == item.TotalPackageCount)
                                publishBadgeClass = "bg-success";
                            else if (item.PublishedCount > 0)
                                publishBadgeClass = "bg-warning text-dark";
                            else
                                publishBadgeClass = "bg-danger";
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Package.Id" class="text-decoration-none">
                                        <strong>@item.Package.Name</strong>
                                    </a>
                                </td>
                                <td><span class="badge bg-dark">@item.Package.Distro</span></td>
                                <td><span class="badge bg-dark">@item.Package.Component</span></td>
                                <td>
                                    <span class="badge @publishBadgeClass">
                                        @item.PublishedCount/@item.TotalPackageCount
                                    </span>
                                </td>
                                <td style="max-width: 200px;">
                                    @if (item.LiveVersions.Count > 0)
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var version in item.LiveVersions)
                                            {
                                                <span class="badge bg-info">@version</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <small class="text-muted">—</small>
                                    }
                                </td>
                                <td><span class="badge @statusClass">@statusText</span></td>
                                <td>
                                    @if (item.NextVersionRevisionId.HasValue)
                                    {
                                        <a asp-action="Details" asp-route-id="@item.Package.Id" asp-route-tab="versions" class="badge bg-warning text-dark text-decoration-none">
                                            @item.NextVersionSummary
                                        </a>
                                    }
                                    else
                                    {
                                        <small class="text-muted">—</small>
                                    }
                                </td>
                                <td><label data-utc-time="@revision!.UploadedAt.ToHtmlDateTime()"></label></td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        @if (item.IsUnpublished)
                                        {
                                            <span class="badge bg-warning text-dark me-1">Unpublished</span>
                                        }
                                        <a asp-action="Details" asp-route-id="@item.Package.Id" asp-route-tab="versions" class="btn btn-sm btn-outline-info" title="@Localizer["Version History"]">
                                            <i class="align-middle" data-lucide="history"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Package.Id" class="btn btn-sm btn-outline-info" title="@Localizer["Details"]">
                                            <i class="align-middle" data-lucide="eye"></i>
                                        </a>
                                        @if (revision.IsListed)
                                        {
                                            <a asp-action="Unlist" asp-route-id="@revision.Id" class="btn btn-sm btn-outline-warning" title="@Localizer["Unlist"]">
                                                <i class="align-middle" data-lucide="archive-x"></i>
                                            </a>
                                        }
                                        else if (Model.IsAdmin)
                                        {
                                            <form method="post" asp-action="Relist" asp-route-id="@revision.Id" class="d-inline" title="@Localizer["Relist"]">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    <i class="align-middle" data-lucide="archive-restore"></i>
                                                </button>
                                            </form>
                                        }
                                        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deletePackage-@item.Package.Id" title="@Localizer["Delete Package"]">
                                            <i class="align-middle" data-lucide="folder-x"></i>
                                        </button>
                                    </div>

                                    <div class="modal fade" id="deletePackage-@item.Package.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content text-start">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">@Localizer["Delete Package Family"]</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@Localizer["Close"]"></button>
                                                </div>
                                                <div class="modal-body">
                                                    @Localizer["This will permanently delete the entire package family"] <strong>@item.Package.Name</strong> (@item.Package.Distro/@item.Package.Component) @Localizer["and ALL its revisions and local packages. The package name will be released for other users. This cannot be undone."]
                                                </div>
                                                <div class="modal-footer">
                                                    <form method="post" asp-action="DeletePackage" asp-route-id="@item.Package.Id">
                                                        @Html.AntiForgeryToken()
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                                                        <button type="submit" class="btn btn-danger">@Localizer["Delete Entire Package"]</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
            </div>
        </div>
    </div>
    <div class="d-none d-xl-block col-xl-2">
        <div class="card border-primary">
            <div class="card-body">
                <div class="text-center mb-3">
                    <i data-lucide="inbox" style="width:48px;height:48px;"></i>
                </div>
                <h6 class="mb-2">@Localizer["What is a mixed package?"]</h6>
                <p class="text-muted small mb-2">@Localizer["An .apkg mixed package is Apkg's proprietary format that bundles multiple .deb packages into a single upload. After processing, each contained .deb is extracted and synced to its target APT repository."]</p>
                <p class="text-muted small mb-0"><strong>@Localizer["Tip:"]</strong> @Localizer["Upload via CLI with <code>apkg push</code> or use the Web UI. Uploads must be published before they appear in repositories."]</p>
            </div>
        </div>
    </div>
</div>
