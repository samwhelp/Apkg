@using Aiursoft.Apkg.Models.ApkgDebPackagesViewModels
@model Aiursoft.Apkg.Models.ApkgPackagesViewModels.ApkgPackagesDetailsViewModel
@{
    var pkg = Model.Package;
}

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-2">
            <i class="align-middle me-1" data-lucide="arrow-left"></i>
            Back to Packages
        </a>
    </div>
    <div class="col-auto">
        <h3 class="mb-0">@pkg.Name</h3>
    </div>
</div>

<div class="row">
    <div class="col-xl-10">
        @{
            var skippedWarnings = TempData["SkippedRepoWarnings"] as string;
            if (!string.IsNullOrWhiteSpace(skippedWarnings))
            {
                <div class="alert alert-warning d-flex align-items-start gap-2 mb-3" role="alert">
                    <i data-lucide="triangle-alert" style="width:18px;height:18px;flex-shrink:0;margin-top:2px;"></i>
                    <div>
                        <strong>Some repositories were skipped during publish</strong> because you do not have permission to upload to them:
                        <ul class="mb-0 mt-1">
                            @foreach (var repo in skippedWarnings.Split('|', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <li><code>@repo</code></li>
                            }
                        </ul>
                    </div>
                </div>
            }
        }
        <div class="card">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs">
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "overview" ? "active" : "")"
                           asp-action="Details" asp-route-id="@pkg.Id" asp-route-tab="overview">
                            <i class="align-middle me-1" data-lucide="info"></i> Overview
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "versions" ? "active" : "")"
                           asp-action="Details" asp-route-id="@pkg.Id" asp-route-tab="versions" asp-route-versionsFilter="@Model.VersionsFilter">
                            <i class="align-middle me-1" data-lucide="history"></i> Versions
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "history" ? "active" : "")"
                           asp-action="Details" asp-route-id="@pkg.Id" asp-route-tab="history">
                            <i class="align-middle me-1" data-lucide="upload-cloud"></i> Upload History
                            @if (Model.UploadHistory.Count > 0)
                            {
                                <span class="badge bg-secondary ms-1">@Model.UploadHistory.Count</span>
                            }
                        </a>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                @if (Model.ActiveTab == "overview")
                {
                    @* ── Overview Tab ── *@
                    var unpublishedRevisions = Model.UploadHistory
                        .Where(uh => uh.Revision.TempApkgFileInVaultPath != null)
                        .ToList();
                    @if (unpublishedRevisions.Count > 0)
                    {
                        <div class="alert alert-warning d-flex align-items-center gap-2 mb-3" role="alert">
                            <i data-lucide="clock" style="width:18px;height:18px;flex-shrink:0;"></i>
                            <div>
                                @unpublishedRevisions.Count unpublished upload(s) pending publish.
                                @foreach (var uh in unpublishedRevisions)
                                {
                                    <a asp-action="Preview" asp-route-vaultPath="@uh.Revision.TempApkgFileInVaultPath" class="alert-link ms-1">Go to Preview →</a>
                                }
                            </div>
                        </div>
                    }
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <label class="form-label text-muted">Package</label>
                            <div><strong>@pkg.Name</strong></div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted">Distro</label>
                            <div><span class="badge bg-dark">@pkg.Distro</span></div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted">Component</label>
                            <div><span class="badge bg-dark">@pkg.Component</span></div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted">Created</label>
                            <div>@pkg.CreatedAt.ToString("yyyy/M/d HH:mm") UTC</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Maintainer</label>
                            <div>@(string.IsNullOrWhiteSpace(pkg.Maintainer) ? "—" : pkg.Maintainer)</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Homepage</label>
                            <div>
                                @if (string.IsNullOrWhiteSpace(pkg.Homepage))
                                {
                                    <span>—</span>
                                }
                                else
                                {
                                    <a href="@pkg.Homepage" target="_blank" rel="noopener noreferrer">@pkg.Homepage</a>
                                }
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted">Description</label>
                            <div>@(string.IsNullOrWhiteSpace(pkg.Description) ? "—" : pkg.Description)</div>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (Model.IsOwner || Model.IsAdmin)
                        {
                            <form method="post" asp-action="DeletePackage" asp-route-id="@pkg.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger"
                                        onclick="return confirm('Permanently delete the entire package family @pkg.Name and ALL its revisions? This cannot be undone.')">
                                    <i class="align-middle me-1" data-lucide="folder-x"></i> Delete Package
                                </button>
                            </form>
                        }
                    </div>

                    <h6 class="mb-3">Effective Packages</h6>
                    <p class="text-muted small mb-2">Latest version per (Architecture, Suite) across all uploads. These are the debs that will be sent to APT repositories.</p>
                    @if (!Model.EffectivePackages.Any())
                    {
                        <p class="text-muted mb-0">No packages have been uploaded yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Package</th>
                                        <th>Version</th>
                                        <th>Architecture</th>
                                        <th>Suite</th>
                                        <th>Uploaded At</th>
                                        <th>Sync Status</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var info in Model.EffectivePackages)
                                    {
                                        var deb = info.Package;
                                        var uploadedAt = deb.ApkgRevision?.UploadedAt;
                                        <tr>
                                            <td><strong>@deb.Package</strong></td>
                                            <td><span class="badge bg-info">@deb.Version</span></td>
                                            <td><span class="badge bg-dark">@deb.Architecture</span></td>
                                            <td><small>@(deb.Repository?.Suite ?? "—")</small></td>
                                            <td>
                                                <small class="text-muted">
                                                    @(uploadedAt.HasValue ? uploadedAt.Value.ToString("yyyy/M/d HH:mm") : "—")
                                                </small>
                                            </td>
                                            <td>
                                                @switch (info.Status)
                                                {
                                                    case LocalPackageStatus.Live:
                                                        <span class="badge bg-success" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="check-circle" style="width:12px; height:12px;"></i> Live
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.StagedForSigning:
                                                        <span class="badge bg-info" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="clock" style="width:12px; height:12px;"></i> Staged
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.PendingSync:
                                                        <span class="badge bg-warning text-dark" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="refresh-cw" style="width:12px; height:12px;"></i> Pending Sync
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.Superseded:
                                                        <span class="badge bg-secondary" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="archive" style="width:12px; height:12px;"></i> Superseded
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.Disabled:
                                                        <span class="badge bg-secondary" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="slash" style="width:12px; height:12px;"></i> Disabled
                                                        </span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (info.Status == LocalPackageStatus.Live && info.LivePackageId.HasValue)
                                                {
                                                    <a asp-controller="Repositories" asp-action="PackageDetails" asp-route-id="@info.LivePackageId.Value" class="btn btn-sm btn-outline-info">
                                                        <i class="align-middle" data-lucide="external-link"></i>
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
                else if (Model.ActiveTab == "history")
                {
                    @* ── Upload History Tab ── *@
                    @if (!Model.UploadHistory.Any())
                    {
                        <p class="text-muted mb-0">No upload history yet.</p>
                    }
                    else
                    {
                        @foreach (var uploadItem in Model.UploadHistory)
                        {
                            var rev = uploadItem.Revision;
                            var isUnpublished = rev.TempApkgFileInVaultPath != null;
                            <div class="card mb-3 @(isUnpublished ? "border-warning" : "")">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@rev.FileName</strong>
                                        @if (isUnpublished)
                                        {
                                            <span class="badge bg-warning text-dark ms-2">Unpublished</span>
                                        }
                                        @if (!rev.IsListed)
                                        {
                                            <span class="badge bg-secondary ms-2">Unlisted</span>
                                        }
                                    </div>
                                    <div class="d-flex gap-2">
                                        <small class="text-muted align-self-center">
                                            @rev.UploadedAt.ToString("yyyy/M/d HH:mm") UTC
                                            by @(rev.UploadedByUser?.UserName ?? "—")
                                        </small>
                                        @if (isUnpublished)
                                        {
                                            <a asp-action="Preview" asp-route-vaultPath="@rev.TempApkgFileInVaultPath" class="btn btn-sm btn-primary">Publish</a>
                                        }
                                        @if (!isUnpublished && rev.IsListed && (Model.IsOwner || Model.IsAdmin))
                                        {
                                            <form method="post" asp-action="Unlist" asp-route-id="@rev.Id" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-warning">Unlist</button>
                                            </form>
                                        }
                                    </div>
                                </div>
                                <div class="card-body">
                                    @if (!uploadItem.DebStatuses.Any())
                                    {
                                        <p class="text-muted mb-0 small">No debs in this upload. The .apkg has not been published yet.</p>
                                    }
                                    else
                                    {
                                        <table class="table table-sm table-striped mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Package</th>
                                                    <th>Version</th>
                                                    <th>Architecture</th>
                                                    <th>Suite</th>
                                                    <th>Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var info in uploadItem.DebStatuses)
                                                {
                                                    var deb = info.Package;
                                                    <tr>
                                                        <td><strong>@deb.Package</strong></td>
                                                        <td><span class="badge bg-info">@deb.Version</span></td>
                                                        <td><span class="badge bg-dark">@deb.Architecture</span></td>
                                                        <td><small>@(deb.Repository?.Suite ?? "—")</small></td>
                                                        <td>
                                                            @switch (info.Status)
                                                            {
                                                                case LocalPackageStatus.Live:
                                                                    <span class="badge bg-success">Live</span>
                                                                    break;
                                                                case LocalPackageStatus.StagedForSigning:
                                                                    <span class="badge bg-info">Staged</span>
                                                                    break;
                                                                case LocalPackageStatus.PendingSync:
                                                                    <span class="badge bg-warning text-dark">Pending Sync</span>
                                                                    break;
                                                                case LocalPackageStatus.Superseded:
                                                                    <span class="badge bg-secondary">Superseded</span>
                                                                    break;
                                                                case LocalPackageStatus.Disabled:
                                                                    <span class="badge bg-secondary">Disabled</span>
                                                                    break;
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </div>
                            </div>
                        }
                    }
                }
                else
                {
                    @* ── Versions Tab ── *@
                    var uploadDates = Model.UploadHistory
                        .ToDictionary(uh => uh.Revision.Id, uh => uh.Revision.UploadedAt);
                    var uploaderDict = Model.UploadHistory
                        .ToDictionary(uh => uh.Revision.Id, uh => uh.Revision.UploadedByUser?.UserName ?? "—");

                    var latestRevisionId = Model.UploadHistory
                        .FirstOrDefault(uh => uh.Revision.TempApkgFileInVaultPath == null)?.Revision.Id;

                    var filteredPkgs = (Model.VersionsFilter switch
                    {
                        "live" => Model.AllPackageStatuses
                            .Where(ps => ps.Status == LocalPackageStatus.Live),
                        "all" => Model.AllPackageStatuses.AsEnumerable(),
                        _ => Model.AllPackageStatuses
                            .Where(ps => ps.Package.ApkgRevisionId == latestRevisionId)
                    })
                        .OrderByDescending(ps => ps.Package.ApkgRevisionId.HasValue
                            ? uploadDates.GetValueOrDefault(ps.Package.ApkgRevisionId.Value)
                            : DateTime.MinValue)
                        .ThenBy(ps => ps.Package.Architecture)
                        .ThenBy(ps => ps.Package.Repository?.Suite ?? "")
                        .ToList();

                    <div class="d-flex gap-2 mb-3">
                        <a asp-action="Details" asp-route-id="@pkg.Id" asp-route-tab="versions" asp-route-versionsFilter="latest"
                           class="btn btn-sm @(Model.VersionsFilter == "latest" ? "btn-primary" : "btn-outline-secondary")">
                            Latest
                        </a>
                        <a asp-action="Details" asp-route-id="@pkg.Id" asp-route-tab="versions" asp-route-versionsFilter="live"
                           class="btn btn-sm @(Model.VersionsFilter == "live" ? "btn-primary" : "btn-outline-secondary")">
                            Live
                        </a>
                        <a asp-action="Details" asp-route-id="@pkg.Id" asp-route-tab="versions" asp-route-versionsFilter="all"
                           class="btn btn-sm @(Model.VersionsFilter == "all" ? "btn-primary" : "btn-outline-secondary")">
                            All
                        </a>
                        <small class="text-muted align-self-center ms-1">@filteredPkgs.Count package(s)</small>
                    </div>

                    @if (!filteredPkgs.Any())
                    {
                        <p class="text-muted mb-0">No packages match this filter.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Architecture</th>
                                        <th>Version</th>
                                        <th>Suite</th>
                                        <th>Sync Status</th>
                                        <th>Uploaded</th>
                                        @if (Model.IsAdmin)
                                        {
                                            <th>Uploader</th>
                                        }
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ps in filteredPkgs)
                                    {
                                        var deb = ps.Package;
                                        var uploadedAt = deb.ApkgRevisionId.HasValue
                                            ? uploadDates.GetValueOrDefault(deb.ApkgRevisionId.Value)
                                            : (DateTime?)null;
                                        var isFromLatest = deb.ApkgRevisionId == latestRevisionId;
                                        <tr>
                                            <td>
                                                <span class="badge bg-dark">@deb.Architecture</span>
                                                @if (isFromLatest)
                                                {
                                                    <span class="badge bg-success ms-1">Newest</span>
                                                }
                                            </td>
                                            <td><span class="badge bg-info">@deb.Version</span></td>
                                            <td><small>@(deb.Repository?.Suite ?? "—")</small></td>
                                            <td>
                                                @switch (ps.Status)
                                                {
                                                    case LocalPackageStatus.Live:
                                                        <span class="badge bg-success">Live</span>
                                                        break;
                                                    case LocalPackageStatus.StagedForSigning:
                                                        <span class="badge bg-info">Staged</span>
                                                        break;
                                                    case LocalPackageStatus.PendingSync:
                                                        <span class="badge bg-warning text-dark">Pending Sync</span>
                                                        break;
                                                    case LocalPackageStatus.Superseded:
                                                        <span class="badge bg-secondary">Superseded</span>
                                                        break;
                                                    case LocalPackageStatus.Disabled:
                                                        <span class="badge bg-secondary">Disabled</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @(uploadedAt.HasValue ? uploadedAt.Value.ToString("yyyy/M/d HH:mm") : "—")
                                                </small>
                                            </td>
                                            @if (Model.IsAdmin)
                                            {
                                                var uploader = deb.ApkgRevisionId.HasValue
                                                    ? uploaderDict.GetValueOrDefault(deb.ApkgRevisionId.Value, "—")
                                                    : "—";
                                                <td><small>@uploader</small></td>
                                            }
                                            <td class="text-end">
                                                @if (ps.Status == LocalPackageStatus.Live && ps.LivePackageId.HasValue)
                                                {
                                                    <a asp-controller="Repositories" asp-action="PackageDetails" asp-route-id="@ps.LivePackageId.Value"
                                                       class="btn btn-sm btn-outline-info" title="View in repository">
                                                        <i class="align-middle" data-lucide="external-link"></i>
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <div class="d-none d-xl-block col-xl-2">
        <div class="card mb-3 border-primary">
            <div class="card-body">
                <div class="text-center mb-3">
                    <i data-lucide="inbox" style="width:48px;height:48px;"></i>
                </div>
                <h6 class="mb-2">@Localizer["What is an APKG Mixed Package?"]</h6>
                <p class="text-muted small mb-2">@Localizer["An .apkg mixed package is Apkg's proprietary format that bundles multiple .deb packages and a manifest.xml into a single gzipped tar archive. The server unpacks each .deb, extracts metadata from its control file, and syncs them to their target APT repositories."]</p>
                <hr />
                <h6 class="mb-2">@Localizer["Dead (Invariant) Attributes"]</h6>
                <p class="text-muted small mb-2">@Localizer["Every .apkg has three <strong>dead attributes</strong> defined at the manifest root that apply to the entire bundle: <strong>Name</strong>, <strong>Distro</strong>, and <strong>Component</strong>. These identify the package family and its target repository. They cannot vary between entries within a single .apkg."]</p>
                <hr />
                <h6 class="mb-2">@Localizer["Live (Variant) Attributes"]</h6>
                <p class="text-muted small mb-2">@Localizer["Within a single .apkg, each entry may vary on three <strong>live attributes</strong>: <strong>Version</strong> (extracted from the .deb binary, never written in manifest.xml), <strong>Suite</strong>, and <strong>Architecture</strong>. This lets you ship e.g. amd64 and arm64 builds of the same version in one upload."]</p>
                <hr />
                <p class="text-muted small mb-0"><strong>@Localizer["Tip:"]</strong> @Localizer["Use <code>apkg push</code> from the CLI to create and upload .apkg files. Uploads must be published before they appear in APT repositories."]</p>
            </div>
        </div>
    </div>
</div>
