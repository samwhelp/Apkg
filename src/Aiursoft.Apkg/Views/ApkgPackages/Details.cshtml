@using Aiursoft.Apkg.Models.ApkgDebPackagesViewModels
@model Aiursoft.Apkg.Models.ApkgPackagesViewModels.ApkgPackagesDetailsViewModel
@{
    var pkg_identity = Model.Revision.ApkgPackage;
}

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-2">
            <i class="align-middle me-1" data-lucide="arrow-left"></i>
            Back to Packages
        </a>
    </div>
    <div class="col-auto">
        <h3 class="mb-0">@pkg_identity?.Name</h3>
    </div>
    <div class="col-auto">
        @if (Model.Revision.IsListed)
        {
            <span class="badge bg-success">Listed</span>
        }
        else
        {
            <span class="badge bg-secondary">Unlisted</span>
        }
    </div>
</div>

<div class="row">
    <div class="col-xl-10">
        @{
            var skippedWarnings = TempData["SkippedRepoWarnings"] as string;
            if (!string.IsNullOrWhiteSpace(skippedWarnings))
            {
                <div class="alert alert-warning d-flex align-items-start gap-2 mb-3" role="alert">
                    <i data-lucide="triangle-alert" style="width:18px;height:18px;flex-shrink:0;margin-top:2px;"></i>
                    <div>
                        <strong>Some repositories were skipped during publish</strong> because you do not have permission to upload to them:
                        <ul class="mb-0 mt-1">
                            @foreach (var repo in skippedWarnings.Split('|', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <li><code>@repo</code></li>
                            }
                        </ul>
                    </div>
                </div>
            }
        }
        <div class="card">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs">
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "overview" ? "active" : "")"
                           asp-action="Details" asp-route-id="@Model.Revision.Id" asp-route-tab="overview">
                            <i class="align-middle me-1" data-lucide="info"></i> Overview
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.ActiveTab == "versions" ? "active" : "")"
                           asp-action="Details" asp-route-id="@Model.Revision.Id" asp-route-tab="versions" asp-route-versionsFilter="@Model.VersionsFilter">
                            <i class="align-middle me-1" data-lucide="history"></i> Versions
                            @{ var publishedCount = Model.VersionHistory.Count(v => v.TempApkgFileInVaultPath == null); }
                            @if (publishedCount > 0)
                            {
                                <span class="badge bg-secondary ms-1">@publishedCount</span>
                            }
                        </a>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                @{
                    var uploadDates = Model.VersionHistory
                        .ToDictionary(vv => vv.Id, vv => vv.UploadedAt);
                    var uploaderDict = Model.VersionHistory
                        .ToDictionary(vv => vv.Id, vv => vv.UploadedByUser?.UserName ?? "—");
                    var uploadListedDict = Model.VersionHistory
                        .ToDictionary(vv => vv.Id, vv => vv.IsListed);

                    var filteredPkgs = (Model.VersionsFilter switch
                    {
                        "live" => Model.AllPackageStatuses
                            .Where(ps => ps.Status == LocalPackageStatus.Live),
                        "all" => Model.AllPackageStatuses.AsEnumerable(),
                        _ => Model.AllPackageStatuses
                            .Where(ps => ps.Package.ApkgRevisionId == Model.LatestVersionId)
                    })
                    .OrderByDescending(ps => ps.Package.ApkgRevisionId.HasValue
                        ? uploadDates.GetValueOrDefault(ps.Package.ApkgRevisionId.Value)
                        : DateTime.MinValue)
                    .ThenBy(ps => ps.Package.Architecture)
                    .ThenBy(ps => ps.Package.Repository?.Suite ?? "")
                    .ToList();
                }
                @if (Model.ActiveTab == "overview")
                {
                    @* ── Overview Tab ── *@
                    @if (Model.Revision.TempApkgFileInVaultPath != null)
                    {
                        <div class="alert alert-warning d-flex align-items-center gap-2 mb-3" role="alert">
                            <i data-lucide="clock" style="width:18px;height:18px;flex-shrink:0;"></i>
                            <div>
                                This upload has not been published yet. No packages have been generated.
                                <a asp-action="Preview" asp-route-vaultPath="@Model.Revision.TempApkgFileInVaultPath" class="alert-link ms-1">Go to Preview to Publish →</a>
                            </div>
                        </div>
                    }
                    @if (Model.LatestVersionId.HasValue && Model.Revision.Id != Model.LatestVersionId)
                    {
                        <div class="alert alert-info d-flex align-items-center gap-2 mb-3" role="alert">
                            <i data-lucide="info" style="width:18px;height:18px;flex-shrink:0;"></i>
                            <div>
                                A newer version of <strong>@pkg_identity?.Name</strong> was uploaded.
                                <a asp-action="Details" asp-route-id="@Model.LatestVersionId" class="alert-link ms-1">View the latest version →</a>
                            </div>
                        </div>
                    }
                    <div class="row g-3 mb-3">
                        @{
                            var distro = pkg_identity?.Distro;
                        }
                        <div class="col-md-3">
                            <label class="form-label text-muted">Package</label>
                            <div><strong>@pkg_identity?.Name</strong></div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted">Distro</label>
                            <div><span class="badge bg-dark">@distro</span></div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted">Component</label>
                            <div><span class="badge bg-dark">@pkg_identity?.Component</span></div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted">Uploaded At</label>
                            <div>@Model.Revision.UploadedAt.ToString("yyyy/M/d HH:mm") UTC</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-muted">Uploader</label>
                            <div>@(Model.Revision.UploadedByUser?.UserName ?? "—")</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Maintainer</label>
                            <div>@(string.IsNullOrWhiteSpace(pkg_identity?.Maintainer) ? "—" : pkg_identity.Maintainer)</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Homepage</label>
                            <div>
                                @if (string.IsNullOrWhiteSpace(pkg_identity?.Homepage))
                                {
                                    <span>—</span>
                                }
                                else
                                {
                                    <a href="@pkg_identity.Homepage" target="_blank" rel="noopener noreferrer">@pkg_identity.Homepage</a>
                                }
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted">Description</label>
                            <div>@(string.IsNullOrWhiteSpace(pkg_identity?.Description) ? "—" : pkg_identity.Description)</div>
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (Model.Revision.IsListed && (Model.IsOwner || Model.IsAdmin))
                        {
                            <form method="post" asp-action="Unlist" asp-route-id="@Model.Revision.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-warning">Unlist</button>
                            </form>
                        }
                        else if (!Model.Revision.IsListed && Model.IsAdmin)
                        {
                            <form method="post" asp-action="Relist" asp-route-id="@Model.Revision.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success">Relist</button>
                            </form>
                        }

                        @if (Model.IsAdmin)
                        {
                            <form method="post" asp-action="Delete" asp-route-id="@Model.Revision.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        }
                    </div>

                    <h6 class="mb-3">Generated Local Packages</h6>
                    @if (!Model.Packages.Any())
                    {
                        <p class="text-muted mb-0">No Local Packages were generated for this upload.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Package</th>
                                        <th>Version</th>
                                        <th>Architecture</th>
                                        <th>Suite</th>
                                        <th>Sync Status</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var info in Model.Packages)
                                    {
                                        var pkg = info.Package;
                                        <tr>
                                            <td><strong>@pkg.Package</strong></td>
                                            <td><span class="badge bg-info">@pkg.Version</span></td>
                                            <td><span class="badge bg-dark">@pkg.Architecture</span></td>
                                            <td><small>@(pkg.Repository?.Suite ?? "—")</small></td>
                                            <td>
                                                @switch (info.Status)
                                                {
                                                    case LocalPackageStatus.Live:
                                                        <span class="badge bg-success" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="check-circle" style="width:12px; height:12px;"></i> Live
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.StagedForSigning:
                                                        <span class="badge bg-info" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="clock" style="width:12px; height:12px;"></i> Staged
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.PendingSync:
                                                        <span class="badge bg-warning text-dark" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="refresh-cw" style="width:12px; height:12px;"></i> Pending Sync
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.Superseded:
                                                        <span class="badge bg-secondary" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="archive" style="width:12px; height:12px;"></i> Superseded
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.Disabled:
                                                        <span class="badge bg-secondary" title="@info.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="slash" style="width:12px; height:12px;"></i> Disabled
                                                        </span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (info.Status == LocalPackageStatus.Live && info.LivePackageId.HasValue)
                                                {
                                                    <a asp-controller="Repositories" asp-action="PackageDetails" asp-route-id="@info.LivePackageId.Value" class="btn btn-sm btn-outline-info">
                                                        <i class="align-middle" data-lucide="external-link"></i>
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
                else
                {
                    @* ── Versions Tab ── *@

                    <div class="d-flex gap-2 mb-3">
                        <a asp-action="Details" asp-route-id="@Model.Revision.Id" asp-route-tab="versions" asp-route-versionsFilter="latest"
                           class="btn btn-sm @(Model.VersionsFilter == "latest" ? "btn-primary" : "btn-outline-secondary")">
                            Latest
                        </a>
                        <a asp-action="Details" asp-route-id="@Model.Revision.Id" asp-route-tab="versions" asp-route-versionsFilter="live"
                           class="btn btn-sm @(Model.VersionsFilter == "live" ? "btn-primary" : "btn-outline-secondary")">
                            Live
                        </a>
                        <a asp-action="Details" asp-route-id="@Model.Revision.Id" asp-route-tab="versions" asp-route-versionsFilter="all"
                           class="btn btn-sm @(Model.VersionsFilter == "all" ? "btn-primary" : "btn-outline-secondary")">
                            All
                        </a>
                        <small class="text-muted align-self-center ms-1">@filteredPkgs.Count package(s)</small>
                    </div>

                    @if (!filteredPkgs.Any())
                    {
                        <p class="text-muted mb-0">No packages match this filter.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Architecture</th>
                                        <th>Version</th>
                                        <th>Suite</th>
                                        <th>Sync Status</th>
                                        <th>Uploaded</th>
                                        @if (Model.IsAdmin)
                                        {
                                            <th>Uploader</th>
                                        }
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ps in filteredPkgs)
                                    {
                                        var pkg = ps.Package;
                                        var uploadedAt = pkg.ApkgRevisionId.HasValue
                                            ? uploadDates.GetValueOrDefault(pkg.ApkgRevisionId.Value)
                                            : (DateTime?)null;
                                        var isFromCurrentView = pkg.ApkgRevisionId == Model.Revision.Id;
                                        <tr class="@(isFromCurrentView ? "table-active" : "")">
                                            <td>
                                                <span class="badge bg-dark">@pkg.Architecture</span>
                                                @if (pkg.ApkgRevisionId == Model.LatestVersionId)
                                                {
                                                    <span class="badge bg-success ms-1">Newest</span>
                                                }
                                                @if (isFromCurrentView)
                                                {
                                                    <small class="text-muted ms-1">(this upload)</small>
                                                }
                                            </td>
                                            <td><span class="badge bg-info">@pkg.Version</span></td>
                                            <td><small>@(pkg.Repository?.Suite ?? "—")</small></td>
                                            <td>
                                                @switch (ps.Status)
                                                {
                                                    case LocalPackageStatus.Live:
                                                        <span class="badge bg-success" title="@ps.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="check-circle" style="width:12px;height:12px;"></i> Live
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.StagedForSigning:
                                                        <span class="badge bg-info" title="@ps.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="clock" style="width:12px;height:12px;"></i> Signing
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.PendingSync:
                                                        <span class="badge bg-warning text-dark" title="@ps.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="refresh-cw" style="width:12px;height:12px;"></i> Syncing
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.Superseded:
                                                        <span class="badge bg-secondary"
                                                              data-bs-toggle="tooltip"
                                                              title="Superseded — a newer version is live. This deb file remains in CAS storage until the garbage collection job runs (~70 min) and removes unreferenced content.">
                                                            <i class="align-middle me-1" data-lucide="archive" style="width:12px;height:12px;"></i> Superseded
                                                        </span>
                                                        break;
                                                    case LocalPackageStatus.Disabled:
                                                        <span class="badge bg-secondary" title="@ps.StatusMessage">
                                                            <i class="align-middle me-1" data-lucide="slash" style="width:12px;height:12px;"></i> Disabled
                                                        </span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">Unknown</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @(uploadedAt.HasValue ? uploadedAt.Value.ToString("yyyy/M/d HH:mm") : "—")
                                                </small>
                                            </td>
                                            @if (Model.IsAdmin)
                                            {
                                                var uploader = pkg.ApkgRevisionId.HasValue
                                                    ? uploaderDict.GetValueOrDefault(pkg.ApkgRevisionId.Value, "—")
                                                    : "—";
                                                <td><small>@uploader</small></td>
                                            }
                                            <td class="text-end">
                                                <div class="btn-group">
                                                    @if (ps.Status == LocalPackageStatus.Live && ps.LivePackageId.HasValue)
                                                    {
                                                        <a asp-controller="Repositories" asp-action="PackageDetails" asp-route-id="@ps.LivePackageId.Value"
                                                           class="btn btn-sm btn-outline-info" title="View in repository">
                                                            <i class="align-middle" data-lucide="external-link"></i>
                                                        </a>
                                                    }
                                                    @if (pkg.ApkgRevisionId.HasValue && pkg.ApkgRevisionId.Value != Model.Revision.Id)
                                                    {
                                                        <a asp-action="Details" asp-route-id="@pkg.ApkgRevisionId.Value"
                                                           class="btn btn-sm btn-outline-secondary" title="View upload details">
                                                            <i class="align-middle" data-lucide="eye"></i>
                                                        </a>
                                                    }
                                                    @if (pkg.ApkgRevisionId.HasValue)
                                                    {
                                                        var uploadIdForBtn = pkg.ApkgRevisionId.Value;
                                                        var isListedForBtn = uploadListedDict.GetValueOrDefault(uploadIdForBtn, false);
                                                        if (isListedForBtn && (Model.IsOwner || Model.IsAdmin))
                                                        {
                                                            <button type="button" class="btn btn-sm btn-outline-warning"
                                                                    data-bs-toggle="modal" data-bs-target="#unlistUpload-@uploadIdForBtn" title="Unlist">
                                                                <i class="align-middle" data-lucide="archive-x"></i>
                                                            </button>
                                                        }
                                                        if (Model.IsAdmin)
                                                        {
                                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                                    data-bs-toggle="modal" data-bs-target="#deleteUpload-@uploadIdForBtn" title="Delete">
                                                                <i class="align-middle" data-lucide="trash-2"></i>
                                                            </button>
                                                        }
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @foreach (var histRevision in Model.VersionHistory
                        .Where(v => filteredPkgs.Any(ps => ps.Package.ApkgRevisionId == v.Id)))
                    {
                        if (histRevision.IsListed && (Model.IsOwner || Model.IsAdmin))
                        {
                            <div class="modal fade" id="unlistUpload-@histRevision.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content text-start">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Confirm Unlist</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            Unlist <strong>@pkg_identity?.Name @(histRevision.ApkgDebPackages.FirstOrDefault()?.Version ?? "")</strong>? Generated packages will be disabled.
                                        </div>
                                        <div class="modal-footer">
                                            <form method="post" asp-action="Unlist" asp-route-id="@histRevision.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-warning">Unlist</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        if (Model.IsAdmin)
                        {
                            <div class="modal fade" id="deleteUpload-@histRevision.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content text-start">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Confirm Delete</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            Permanently delete <strong>@pkg_identity?.Name @(histRevision.ApkgDebPackages.FirstOrDefault()?.Version ?? "")</strong> and all generated Local Packages?
                                        </div>
                                        <div class="modal-footer">
                                            <form method="post" asp-action="Delete" asp-route-id="@histRevision.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-danger">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>
    </div>
    <div class="d-none d-xl-block col-xl-2">
        <div class="card mb-3 border-primary">
            <div class="card-body">
                <div class="text-center mb-3">
                    <i data-lucide="inbox" style="width:48px;height:48px;"></i>
                </div>
                <h6 class="mb-2">@Localizer["What is an APKG Mixed Package?"]</h6>
                <p class="text-muted small mb-2">@Localizer["An .apkg mixed package is Apkg's proprietary format that bundles multiple .deb packages and a manifest.xml into a single gzipped tar archive. The server unpacks each .deb, extracts metadata from its control file, and syncs them to their target APT repositories."]</p>
                <hr />
                <h6 class="mb-2">@Localizer["Dead (Invariant) Attributes"]</h6>
                <p class="text-muted small mb-2">@Localizer["Every .apkg has three <strong>dead attributes</strong> defined at the manifest root that apply to the entire bundle: <strong>Name</strong>, <strong>Distro</strong>, and <strong>Component</strong>. These identify the package family and its target repository. They cannot vary between entries within a single .apkg."]</p>
                <hr />
                <h6 class="mb-2">@Localizer["Live (Variant) Attributes"]</h6>
                <p class="text-muted small mb-2">@Localizer["Within a single .apkg, each entry may vary on three <strong>live attributes</strong>: <strong>Version</strong> (extracted from the .deb binary, never written in manifest.xml), <strong>Suite</strong>, and <strong>Architecture</strong>. This lets you ship e.g. amd64 and arm64 builds of the same version in one upload."]</p>
                <hr />
                <p class="text-muted small mb-0"><strong>@Localizer["Tip:"]</strong> @Localizer["Use <code>apkg push</code> from the CLI to create and upload .apkg files. Uploads must be published before they appear in APT repositories."]</p>
            </div>
        </div>
    </div>
</div>
