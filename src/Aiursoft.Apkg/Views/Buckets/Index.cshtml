@model Aiursoft.Apkg.Models.MirrorsViewModels.BucketsIndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>@Localizer["Bucket Snapshots History"]</h3>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="alert alert-info">
            <i class="align-middle me-2" data-lucide="info"></i>
            <strong>GC Policy:</strong> Buckets not referenced by any Mirror or Repository for more than 70 minutes will be automatically pruned.
        </div>
        
        <table class="table table-hover table-striped">
            <thead>
            <tr>
                <th>@Localizer["ID"]</th>
                <th>@Localizer["Status"]</th>
                <th>@Localizer["Created Time"]</th>
                <th class="text-end">@Localizer["Packages"]</th>
                <th class="text-end">@Localizer["Logical Size"]</th>
                <th>@Localizer["Active Usage"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var bucket in Model.Buckets)
            {
                var isLive = !string.IsNullOrEmpty(Model.InUseBy.GetValueOrDefault(bucket.Id));
                <tr>
                    <td><span class="badge bg-secondary">#@bucket.Id</span></td>
                    <td>
                        @if (isLive)
                        {
                            <span class="badge bg-success">@Localizer["LIVE"]</span>
                        }
                        else
                        {
                            <span class="badge badge-subtle-warning">@Localizer["Orphaned / Building"]</span>
                        }
                    </td>
                    <td>@bucket.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td class="text-end"><strong>@Model.PackageCounts.GetValueOrDefault(bucket.Id, 0).ToString("N0")</strong></td>
                    <td class="text-end">@((Model.StorageUsage.GetValueOrDefault(bucket.Id, 0) / 1024.0 / 1024.0).ToString("F2")) MB</td>
                    <td>
                        <small class="text-primary">@Model.InUseBy.GetValueOrDefault(bucket.Id)</small>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
