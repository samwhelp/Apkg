@model Aiursoft.Apkg.Models.DashboardViewModels.IndexViewModel
@{
    var totalPages = (int)Math.Ceiling((double)Model.TotalResults / Aiursoft.Apkg.Models.DashboardViewModels.IndexViewModel.PageSize);
    var hasQuery = !string.IsNullOrWhiteSpace(Model.Query);
}

@* ── Hero / Search bar ─────────────────────────────────────────────── *@
<div class="jumbotron p-4 mb-4" style="background: linear-gradient(135deg,#1a1a2e 0%,#16213e 60%,#0f3460 100%); border-radius:.75rem;">
    <div class="container text-center py-3">
        <h1 class="display-5 fw-bold text-white mb-1">
            <i class="align-middle me-2" data-lucide="package-search"></i> @Localizer["APT Package Search"]
        </h1>
        <p class="text-white-50 mb-4">Search across <strong class="text-white">@Model.TotalPackages.ToString("N0")</strong> packages in <strong class="text-white">@Model.TotalRepos</strong> active repositor@(Model.TotalRepos == 1 ? "y" : "ies")</p>
        <form method="get" asp-action="Index" asp-controller="Dashboard">
            <div class="input-group input-group-lg mx-auto" style="max-width:640px;">
                <span class="input-group-text bg-white border-end-0">
                    <i data-lucide="search" style="width:20px;height:20px;"></i>
                </span>
                <input type="text"
                       name="q"
                       class="form-control border-start-0 ps-0"
                       placeholder="@Localizer["Search packages (e.g. curl, python3, vim…)"]"
                       value="@Model.Query"
                       autofocus />
                <button class="btn btn-primary px-4" type="submit">@Localizer["Search"]</button>
            </div>
        </form>
    </div>
</div>

@* ── Results ───────────────────────────────────────────────────────── *@
@if (hasQuery)
{
    <div class="d-flex align-items-center mb-3 gap-2">
        <span class="text-muted">
            @Model.TotalResults.ToString("N0") @Localizer[Model.TotalResults == 1 ? "result for" : "results for"]
        </span>
        <code class="fs-6">"@Model.Query"</code>
        <a asp-action="Index" asp-controller="Dashboard" class="btn btn-sm btn-outline-secondary ms-auto">
            <i class="align-middle me-1" data-lucide="x"></i> @Localizer["Clear"]
        </a>
    </div>

    @if (!Model.Results.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i data-lucide="package-x" style="width:48px;height:48px;" class="text-muted mb-3"></i>
                <h5 class="text-muted">@Localizer["No packages found matching"] <code>@Model.Query</code></h5>
                <p class="text-muted small mb-0">@Localizer["Try a shorter name or check spelling."]</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var result in Model.Results)
        {
            var pkg = result.Package;
            var sizeKb = long.TryParse(pkg.Size, out var sz) ? sz / 1024.0 : 0;
            var sizeDisplay = sizeKb >= 1024
                ? $"{sizeKb / 1024.0:F1} MB"
                : $"{sizeKb:F0} KB";
            <div class="card mb-2 shadow-sm">
                <div class="card-body py-3">
                    <div class="d-flex align-items-start gap-3">
                        <div class="pt-1">
                            <div class="rounded-2 d-flex align-items-center justify-content-center bg-primary text-white"
                                 style="width:42px;height:42px;flex-shrink:0;">
                                <i data-lucide="box" style="width:22px;height:22px;"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 overflow-hidden">
                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                <a asp-controller="Repositories"
                                   asp-action="PackageDetails"
                                   asp-route-id="@pkg.Id"
                                   class="fs-5 fw-semibold text-decoration-none">
                                    @pkg.Package
                                </a>
                                <span class="badge bg-success">@pkg.Version</span>
                                <span class="badge bg-secondary">@pkg.Component</span>
                                <span class="badge badge-subtle-info">@pkg.Architecture</span>
                                @if (pkg.IsVirtual)
                                {
                                    <span class="badge badge-subtle-warning">@Localizer["Virtual"]</span>
                                }
                                else
                                {
                                    <span class="badge badge-subtle-success">@Localizer["Physical"]</span>
                                }
                            </div>
                            <p class="text-muted mb-1 small text-truncate">
                                @if (string.IsNullOrWhiteSpace(pkg.Description))
                                {
                                    @Localizer["No description."]
                                }
                                else
                                {
                                    @pkg.Description
                                }
                            </p>
                            <div class="d-flex flex-wrap gap-3 small text-muted">
                                @if (!string.IsNullOrWhiteSpace(pkg.Maintainer))
                                {
                                    <span><i data-lucide="user" style="width:13px;height:13px;" class="me-1"></i>@pkg.Maintainer</span>
                                }
                                <span><i data-lucide="hard-drive" style="width:13px;height:13px;" class="me-1"></i>@sizeDisplay</span>
                                <span>
                                    <i data-lucide="database" style="width:13px;height:13px;" class="me-1"></i>
                                    <a asp-controller="Repositories"
                                       asp-action="Details"
                                       asp-route-id="@result.RepoId"
                                       class="text-decoration-none text-muted">@result.RepoName</a>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Pagination *@
        @if (totalPages > 1)
        {
            <nav class="mt-3" aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-q="@Model.Query" asp-route-page="@(Model.Page - 1)">@Localizer["‹ Prev"]</a>
                    </li>
                    @for (var p = Math.Max(1, Model.Page - 2); p <= Math.Min(totalPages, Model.Page + 2); p++)
                    {
                        var pageNum = p;
                        <li class="page-item @(pageNum == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-q="@Model.Query" asp-route-page="@pageNum">@pageNum</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-q="@Model.Query" asp-route-page="@(Model.Page + 1)">@Localizer["Next ›"]</a>
                    </li>
                </ul>
            </nav>
        }
    }
}
else
{
    @* ── Landing hints when no query ────────────────────────────────── *@
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <i data-lucide="search" style="width:36px;height:36px;" class="text-primary mb-2"></i>
                    <h6 class="fw-semibold">@Localizer["Find Packages"]</h6>
                    <p class="text-muted small mb-0">@Localizer["Type a package name above to search across all active repositories in real-time."]</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <i data-lucide="layers" style="width:36px;height:36px;" class="text-success mb-2"></i>
                    <h6 class="fw-semibold">@Localizer["Browse Repositories"]</h6>
                    <p class="text-muted small mb-0">
                        <a asp-controller="Repositories" asp-action="Index">@Localizer["View all repositories"]</a> @Localizer["and browse their packages individually."]
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <i data-lucide="info" style="width:36px;height:36px;" class="text-info mb-2"></i>
                    <h6 class="fw-semibold">@Localizer["How to Use"]</h6>
                    <p class="text-muted small mb-0">@Localizer["Add a repository to your"] <code>sources.list</code> @Localizer["and run"] <code>apt update</code> @Localizer["to get started."]</p>
                </div>
            </div>
        </div>
    </div>
}
