@model Aiursoft.Apkg.Models.MirrorsViewModels.IndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Upstream Mirrors"]</h3>
    </div>
    <div class="col-auto ms-auto text-end">
        <a asp-action="Create" class="btn btn-primary">
            <i class="align-middle" data-lucide="plus"></i> @Localizer["Add New Mirror"]
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped">
            <thead>
            <tr>
                <th>@Localizer["Distro"]</th>
                <th>@Localizer["Suite"]</th>
                <th>@Localizer["Base URL"]</th>
                <th>@Localizer["Components"]</th>
                <th>@Localizer["Arch"]</th>
                <th>@Localizer["Status"]</th>
                <th>@Localizer["Last Pull"]</th>
                <th>
                    @Localizer["Primary Bucket"]
                    <i data-lucide="circle-help" style="width:14px;height:14px;vertical-align:middle;margin-left:3px;cursor:help;"
                       data-bs-toggle="tooltip" data-bs-placement="top"
                       data-bs-title="@Localizer["The live snapshot currently served to apt clients. A new bucket becomes primary only after a Mirror Sync completes successfully."]"></i>
                </th>
                <th>
                    @Localizer["Secondary Bucket"]
                    <i data-lucide="circle-help" style="width:14px;height:14px;vertical-align:middle;margin-left:3px;cursor:help;"
                       data-bs-toggle="tooltip" data-bs-placement="top"
                       data-bs-title="@Localizer["The snapshot being built by a running Mirror Sync job. It replaces the Primary Bucket when the job succeeds; the old primary is then eligible for garbage collection."]"></i>
                </th>
                <th>@Localizer["Packages"]</th>
                <th class="text-end">@Localizer["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Mirrors)
            {
                <tr>
                    <td>
                        <span class="badge badge-subtle-primary">@item.Distro</span>
                        @if (item.AllowInsecure)
                        {
                            <span class="badge badge-subtle-danger" title="@Localizer["Insecure Source"]">
                                <i class="align-middle" data-lucide="shield-off" style="width: 12px; height: 12px;"></i>
                            </span>
                        }
                    </td>
                    <td><span class="badge bg-info">@item.Suite</span></td>
                    <td><small>@item.BaseUrl</small></td>
                    <td><small>@item.Components</small></td>
                    <td><span class="badge bg-dark">@item.Architecture</span></td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.SignedBy) && !item.AllowInsecure)
                        {
                            if (item.LastVerifyLog != null && item.LastVerifyLog.Contains("[GNUPG:] GOODSIG"))
                            {
                                <a asp-action="VerifyDetails" asp-route-id="@item.Id" class="badge bg-success text-decoration-none">
                                    <i class="align-middle" data-lucide="shield-check" style="width: 14px; height: 14px;"></i> @Localizer["Passed"]
                                </a>
                            }
                            else if (item.LastVerifyLog != null)
                            {
                                <a asp-action="VerifyDetails" asp-route-id="@item.Id" class="badge bg-danger text-decoration-none">
                                    <i class="align-middle" data-lucide="shield-alert" style="width: 14px; height: 14px;"></i> @Localizer["Failed"]
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Localizer["Pending"]</span>
                            }
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Localizer["Signature Verification Disabled"]</span>
                        }
                    </td>
                    <td>
                        @if (item.LastPullTime != null)
                        {
                            <small class="d-block text-muted">@item.LastPullTime.Value.ToLocalTime().ToString("g")</small>
                            @if (item.LastPullSuccess == true)
                            {
                                <span class="badge bg-success">@Localizer["Success"]</span>
                                <small class="text-success d-block">@item.LastPullResult</small>
                            }
                            else if (item.LastPullSuccess == false)
                            {
                                <span class="badge bg-danger cursor-pointer" data-bs-toggle="modal" data-bs-target="#errorModal-@item.Id">
                                    @Localizer["Failed"]
                                </span>
                                <small class="text-danger d-block">@item.LastPullResult</small>

                                <!-- Error Stack Modal -->
                                <div class="modal fade" id="errorModal-@item.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-lg">
                                        <div class="modal-content text-start">
                                            <div class="modal-header">
                                                <h5 class="modal-title">@Localizer["Sync Error Stack Trace"]</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <div class="alert alert-danger">
                                                    <strong>@Localizer["Error:"]</strong> @item.LastPullResult
                                                </div>
                                                <pre class="bg-light p-3 border rounded"><code>@item.LastPullErrorStack</code></pre>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Localizer["Never Pull"]</span>
                        }
                    </td>
                    <td>
                        @if (item.PrimaryBucketId != null)
                        {
                            <a asp-controller="Buckets" asp-action="Packages" asp-route-id="@item.PrimaryBucketId" class="badge bg-success text-decoration-none">#@item.PrimaryBucketId</a>
                        }
                        else
                        {
                            <span class="badge bg-warning">@Localizer["Never Synced"]</span>
                        }
                    </td>
                    <td>
                        @if (item.SecondaryBucketId != null)
                        {
                            <a asp-controller="Buckets" asp-action="Packages" asp-route-id="@item.SecondaryBucketId" class="badge bg-info text-decoration-none">#@item.SecondaryBucketId</a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @if (item.PrimaryBucketId != null)
                        {
                            <a asp-action="Packages" asp-route-id="@item.Id" class="badge bg-secondary text-decoration-none">
                                @(Model.PackageCounts.GetValueOrDefault(item.PrimaryBucketId.Value, 0)) @Localizer["items"]
                            </a>
                        }
                    </td>
                    <td class="text-end">
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="align-middle" data-lucide="edit"></i>
                            </a>
                            <a asp-action="Packages" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                <i class="align-middle" data-lucide="package"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteMirror-@item.Id">
                                <i class="align-middle" data-lucide="trash-2"></i>
                            </button>
                        </div>

                        <div class="modal fade" id="deleteMirror-@item.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">@Localizer["Confirm Delete"]</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        @Localizer["Are you sure you want to delete mirror"] <strong>@item.Suite</strong>? 
                                        @Localizer["This will also delete all associated packages and buckets!"]
                                    </div>
                                    <div class="modal-footer">
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                                            <button type="submit" class="btn btn-danger">@Localizer["Delete Mirror"]</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
    </script>
}
