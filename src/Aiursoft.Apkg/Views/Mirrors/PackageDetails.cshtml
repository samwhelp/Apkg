@model Aiursoft.Apkg.Models.MirrorsViewModels.PackageDetailsViewModel
@{
    var pkg = Model.Package;
}

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>@Localizer["Package Details"] - <code>@pkg.Package</code></h3>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">@Localizer["Metadata"]</h5></div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">@Localizer["Version"]</dt>
                    <dd class="col-sm-9"><span class="badge bg-success">@pkg.Version</span></dd>

                    <dt class="col-sm-3">@Localizer["Architecture"]</dt>
                    <dd class="col-sm-9"><code>@pkg.Architecture</code></dd>

                    <dt class="col-sm-3">@Localizer["Description"]</dt>
                    <dd class="col-sm-9"><p class="text-muted">@pkg.Description</p></dd>

                    <dt class="col-sm-3">@Localizer["Maintainer"]</dt>
                    <dd class="col-sm-9">@pkg.Maintainer</dd>

                    @if (!string.IsNullOrWhiteSpace(pkg.Homepage))
                    {
                        <dt class="col-sm-3">@Localizer["Homepage"]</dt>
                        <dd class="col-sm-9"><a href="@pkg.Homepage" target="_blank">@pkg.Homepage</a></dd>
                    }
                </dl>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header"><h5 class="card-title mb-0">@Localizer["Dependencies"]</h5></div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(pkg.Depends))
                {
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var dep in pkg.Depends.Split(','))
                        {
                            <span class="badge badge-subtle-primary">@dep.Trim()</span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">@Localizer["No dependencies."]</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">@Localizer["Status & Files"]</h5></div>
            <div class="card-body">
                <p>
                    <strong>@Localizer["Storage State"]:</strong>
                    @if (pkg.IsVirtual)
                    {
                        <span class="badge bg-warning">@Localizer["Virtual (Lazy Sync)"]</span>
                    }
                    else
                    {
                        <span class="badge bg-success">@Localizer["Physical (Cached)"]</span>
                    }
                </p>
                <p><strong>@Localizer["Size"]:</strong> @(long.Parse(pkg.Size) / 1024) KB</p>
                <p><strong>@Localizer["Component"]:</strong> @pkg.Component</p>
                <hr />
                <h6>@Localizer["Hashes"]</h6>
                <small class="d-block text-break"><strong>SHA256:</strong> @pkg.SHA256</small>
                <small class="d-block text-break"><strong>MD5:</strong> @pkg.MD5sum</small>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-body d-grid gap-2">
                <a href="/@pkg.Filename" class="btn btn-primary">
                    <i class="align-middle me-1" data-lucide="download"></i> @Localizer["Download .deb"]
                </a>
                @if (!string.IsNullOrWhiteSpace(pkg.RemoteUrl))
                {
                    <a href="@pkg.RemoteUrl" target="_blank" class="btn btn-outline-secondary">
                        <i class="align-middle me-1" data-lucide="external-link"></i> @Localizer["Upstream URL"]
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="javascript:history.back()" class="btn btn-secondary">@Localizer["Back"]</a>
</div>
