@using Aiursoft.Apkg.Entities
@model Aiursoft.Apkg.Models.MirrorsViewModels.EditViewModel
@{
    var cert = ViewData["Certificate"] as AptCertificate;
}

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Mirror Details"] - @Model.Suite/@Model.Component</h3>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">@Localizer["Client Setup Instructions"]</h5>
    </div>
    <div class="card-body">
        @if (cert != null)
        {
            <p>@Localizer["This mirror is signed by Apkg. You must install the public key to trust it."]</p>
            
            <h6>1. @Localizer["Download and install the public key:"]</h6>
            <div class="bg-light p-3 rounded mb-3">
                <pre class="mb-0"><code>curl -sL @(Context.Request.Scheme)://@(Context.Request.Host)/certs/@(cert.Id) | sudo tee /etc/apt/trusted.gpg.d/apkg-@(cert.Id).asc > /dev/null</code></pre>
            </div>

            <h6>2. @Localizer["Add this repository to your sources:"]</h6>
            <div class="bg-light p-3 rounded mb-3">
                <pre class="mb-0"><code>echo "deb [signed-by=/etc/apt/trusted.gpg.d/apkg-@(cert.Id).asc] @(Context.Request.Scheme)://@(Context.Request.Host)/ubuntu/ @Model.Suite @Model.Component" | sudo tee /etc/apt/sources.list.d/apkg-@(Model.Id).list</code></pre>
            </div>

            <h6>3. @Localizer["Update and enjoy:"]</h6>
            <div class="bg-light p-3 rounded">
                <pre class="mb-0"><code>sudo apt update</code></pre>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                @Localizer["This mirror has no certificate associated and is in passthrough mode."]
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Back to List"]</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">@Localizer["Edit Settings"]</a>
</div>
