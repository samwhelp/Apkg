@model Aiursoft.Apkg.Models.MirrorsViewModels.CertIndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>@Localizer["Signing Certificates"]</h3>
    </div>
    <div class="col-auto ms-auto">
        <a asp-action="Create" class="btn btn-primary">
            <i class="align-middle" data-lucide="plus"></i> @Localizer["Generate New Key"]
        </a>
    </div>
</div>

<div class="row">
    <div class="col-xl-10">
        <div class="card h-100">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
            <tr>
                <th>@Localizer["Name"]</th>
                <th>@Localizer["Friendly Name"]</th>
                <th>@Localizer["Fingerprint"]</th>
                <th>@Localizer["Created"]</th>
                <th class="text-end">@Localizer["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Certificates)
            {
                <tr>
                    <td><code>@item.Name</code></td>
                    <td><strong>@item.FriendlyName</strong></td>
                    <td><code>@item.Fingerprint</code></td>
                    <td>@item.CreatedAt.ToShortDateString()</td>
                    <td class="text-end">
                        <a asp-controller="AptMirror" asp-action="GetCert" asp-route-name="@item.Name" class="btn btn-sm btn-outline-primary me-1">
                            <i class="align-middle" data-lucide="download"></i>
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteCert-@item.Id">
                            <i class="align-middle" data-lucide="trash-2"></i>
                        </button>

                        <div class="modal fade" id="deleteCert-@item.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">@Localizer["Confirm Delete"]</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        @Localizer["Are you sure you want to delete certificate"] <strong>@item.FriendlyName</strong>? @Localizer["This will break all repositories using it!"]
                                    </div>
                                    <div class="modal-footer">
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                                            <button type="submit" class="btn btn-danger">@Localizer["Delete Forever"]</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
            </div>
        </div>
    </div>
    <div class="d-none d-xl-block col-xl-2">
        <div class="card border-primary">
            <div class="card-body">
                <div class="text-center mb-3">
                    <i data-lucide="key-round" style="width:48px;height:48px;"></i>
                </div>
                <h6 class="mb-2">@Localizer["What is a Certificate?"]</h6>
                <p class="text-muted small mb-2">@Localizer["GPG certificates sign your repository metadata so apt clients can verify that packages haven't been tampered with."]</p>
                <p class="text-muted small mb-0"><strong>@Localizer["Tip:"]</strong> @Localizer["Rotate certificates regularly and keep private keys secure. Unsigned repos require <code>Trusted: yes</code> on the client."]</p>
            </div>
        </div>
    </div>
</div>
