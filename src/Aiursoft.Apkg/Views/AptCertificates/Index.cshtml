@model Aiursoft.Apkg.Models.MirrorsViewModels.CertIndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto">
        <h3>@Localizer["Signing Certificates"]</h3>
    </div>
    <div class="col-auto ms-auto">
        <a asp-action="Create" class="btn btn-primary">
            <i class="align-middle" data-lucide="plus"></i> @Localizer["Generate New Key"]
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
            <tr>
                <th>@Localizer["Name"]</th>
                <th>@Localizer["Friendly Name"]</th>
                <th>@Localizer["Fingerprint"]</th>
                <th>@Localizer["Created"]</th>
                <th class="text-end">@Localizer["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Certificates)
            {
                <tr>
                    <td><code>@item.Name</code></td>
                    <td><strong>@item.FriendlyName</strong></td>
                    <td><code>@item.Fingerprint</code></td>
                    <td>@item.CreatedAt.ToShortDateString()</td>
                    <td class="text-end">
                        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteCert-@item.Id">
                            <i class="align-middle" data-lucide="trash-2"></i>
                        </button>

                        <div class="modal fade" id="deleteCert-@item.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Confirm Delete</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        Are you sure you want to delete certificate <strong>@item.FriendlyName</strong>? This will break all repositories using it!
                                    </div>
                                    <div class="modal-footer">
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-danger">Delete Forever</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
