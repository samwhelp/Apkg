@model Aiursoft.Apkg.Models.UserApiKeysViewModels.UsageViewModel

<div class="container-fluid p-0">
    <div class="row mb-3">
        <div class="col-auto">
            <h1 class="h3 mb-3">@Localizer["API Key Usage Guide"]</h1>
        </div>
        <div class="col-auto ms-auto text-end">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="align-middle me-1" data-lucide="arrow-left"></i>
                @Localizer["Back to List"]
            </a>
        </div>
    </div>

    @if (Model.RawKey != null)
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            <div class="alert-message">
                <h4 class="alert-heading">@Localizer["API Key Created!"]</h4>
                <p>@Localizer["Please copy your new API key now. You won't be able to see it again!"]</p>
                <hr>
                <p class="mb-0">
                    <code>@Model.RawKey</code>
                </p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">@Localizer["Using API Key"]: <strong>@Model.KeyName</strong> (<code>@Model.KeyDisplay</code>)</h5>
        </div>
        <div class="card-body">
            <p>@Localizer["Use this API key to upload packages programmatically. The base URL is:"] <code>@Model.BaseUrl</code></p>

            <h4 class="mt-4">@Localizer["1. Upload an .apkg Package (Recommended)"]</h4>
            <p>@Localizer["Use the <code>apkg</code> CLI to build and push .apkg packages. The apkg tool handles manifest generation, multi-architecture builds, and one-command uploads."]</p>
            <pre class="bg-dark text-light p-3 rounded"><code>apkg push ./bin/my-package.1.0.0.apkg \
  --source @Model.BaseUrl \
  --api-key @(Model.RawKey ?? Model.KeyDisplay)</code></pre>
            <p class="text-muted mt-2">
                <i data-lucide="info" class="me-1"></i>
                @Localizer["Full workflow: <code>apkg new</code> → <code>apkg add</code> → <code>apkg publish</code> → <code>apkg push</code>. Install the CLI with: <code>dotnet tool install -g Aiursoft.Apkg.Client</code>"]
            </p>
        </div>
    </div>
</div>
