@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/styles/site.css" xmlns="http://www.w3.org/1999/html"/>
    <link rel="stylesheet" href="~/styles/marketing.css" xmlns="http://www.w3.org/1999/html"/>
}

<vc:marketing-navbar></vc:marketing-navbar>

<section class="apkg-hero landing-intro text-bg-dark pt-5 pt-lg-6 pb-5 pb-lg-7">
    <div class="landing-intro-content container h-100">
        <div class="row align-items-center h-100">
            <div class="col-lg-5 mx-auto">
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="badge badge-subtle-primary p-2">@Localizer["APT repository server"]</span>
                    <span class="badge badge-subtle-primary p-2">@Localizer[".apkg publishing"]</span>
                    <span class="badge badge-subtle-primary p-2">@Localizer["AnduinOS ready"]</span>
                </div>
                <h1 id="main-slogan" class="my-4 text-white" style="font-size: 3rem;">
                    @Localizer["Apkg"] <span class="text-primary">@Localizer["Repository Platform"]</span>
                </h1>
                <p class="text-lg text-white-50">
                    @Localizer["Host signed Debian package repositories, mirror upstream Ubuntu archives, and publish distribution-specific package overrides without asking client machines to run fragile post-install scripts."]
                </p>
                <form method="get" asp-action="Index" asp-controller="Dashboard" class="apkg-hero-search my-4">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0">
                            <i data-lucide="search" style="width:20px;height:20px;"></i>
                        </span>
                        <input type="text"
                               name="q"
                               maxlength="40"
                               class="form-control border-start-0 ps-0"
                               placeholder="@Localizer["Search packages..."]"
                               aria-label="@Localizer["Search packages"]"/>
                        <button class="btn btn-primary px-4" type="submit">@Localizer["Search"]</button>
                    </div>
                </form>
                <div class="my-4 d-flex flex-wrap gap-3">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="layout-dashboard"></i> @Localizer["Enter Dashboard"]
                    </a>
                    <a asp-controller="Home" asp-action="SelfHost" class="btn btn-outline-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="server"></i> @Localizer["Self Host"]
                    </a>
                    <a href="#quick-start" class="btn btn-outline-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="terminal"></i> @Localizer["Start Publishing"]
                    </a>
                    <a href="https://github.com/aiursoftweb/apkg" target="_blank" class="btn btn-outline-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="github"></i> @Localizer["View on GitHub"]
                    </a>
                </div>
            </div>
            <div class="col-lg-7 d-none d-lg-flex mx-auto text-center">
                <div class="apkg-hero-preview landing-intro-screenshot shadow-lg">
                    <img src="~/images/screenshot.png" alt="@Localizer["Apkg dashboard showing package repository management"]" class="img-fluid rounded"/>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary" id="install-apkg">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h2 class="mb-2">@Localizer["Install APKG CLI"]</h2>
                <p class="text-muted mb-4">@Localizer["A single command to install the APKG client and start managing your APT packages."]</p>
            </div>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">@Localizer["Quick Start"]</h5>
                        <div class="mb-3">
                            <span class="badge badge-subtle-primary me-2">1</span>
                            <strong>@Localizer["Install .NET SDK"]</strong>
                            <p class="text-muted small mt-1 ms-4 ps-1 mb-0">
                                <a href="https://dotnet.microsoft.com/en-us/download" target="_blank">@Localizer["Download .NET SDK"]</a>
                                <span class="mx-1">|</span>
                                @Localizer["Ubuntu:"] <code>sudo apt install dotnet10</code>
                            </p>
                        </div>
                        <div class="mb-3">
                            <span class="badge badge-subtle-primary me-2">2</span>
                            <strong>@Localizer["Install APKG CLI"]</strong>
                            <pre class="bg-dark text-white p-2 rounded small mt-1 ms-4 ps-1 mb-0" style="white-space:pre-wrap;"><code>dotnet tool install -g Aiursoft.Apkg.Client</code></pre>
                            <a rel="nofollow noreferrer noopener" href="https://www.nuget.org/packages/Aiursoft.Apkg.Client/" target="_blank" class="mt-1 ms-4 ps-1 d-inline-block">
                                <img alt="NuGet version (Aiursoft.Apkg.Client)" src="https://img.shields.io/nuget/v/Aiursoft.Apkg.Client.svg">
                            </a>
                        </div>
                        <div class="mb-3">
                            <span class="badge badge-subtle-primary me-2">3</span>
                            <strong>@Localizer["Configure sudo apkg (one-time setup)"]</strong>
                            <p class="text-muted small mt-1 ms-4 ps-1 mb-1">@Localizer["<code>sudo apkg</code> cannot run directly because root's PATH does not include <code>~/.dotnet/tools</code>. Create a symlink once and it works permanently:"]</p>
                            <pre class="bg-dark text-white p-2 rounded small mt-1 ms-4 ps-1 mb-0" style="white-space:pre-wrap;"><code>sudo ln -s ~/.dotnet/tools/apkg /usr/local/bin/apkg</code></pre>
                        </div>
                        <div>
                            <span class="badge badge-subtle-primary me-2">4</span>
                            <strong>@Localizer["Add a source"]</strong>
                            <pre class="bg-dark text-white p-2 rounded small mt-1 ms-4 ps-1 mb-0" style="white-space:pre-wrap;"><code>sudo apkg add-source https://apkg.aiursoft.com/api/sources/{id}</code></pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary border-bottom apkg-stats">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="apkg-metric">
                    <div class="apkg-metric-value">APT</div>
                    <div class="apkg-metric-label">@Localizer["Standard Debian repository endpoints for <code>apt update</code>, <code>apt install</code>, GPG keys, package indexes, and pool downloads."]</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="apkg-metric">
                    <div class="apkg-metric-value">.apkg</div>
                    <div class="apkg-metric-label">@Localizer["Portable publishing bundles with a manifest plus one or more <code>.deb</code> files for multiple suites and architectures."]</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="apkg-metric">
                    <div class="apkg-metric-value">.aosproj</div>
                    <div class="apkg-metric-label">@Localizer["A declarative project file that defines files, folders, scripts, dependencies, systemd services, suites, and architectures — all in one place."]</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Distribution Infrastructure"]</span>
            <h2 class="h1">@Localizer["Everything needed to publish an APT repository."]</h2>
            <p class="text-muted fs-lg mx-auto mb-0" style="max-width: 760px;">
                @Localizer["Apkg sits between upstream archives, package developers, and client machines. It turns mirror metadata and uploaded overrides into signed, stable repository snapshots."]
            </p>
        </div>

        <div class="row">
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="server"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Signed APT hosting"]</h4>
                        <p class="fs-lg">@Localizer["Serve <code>InRelease</code>, <code>Release</code>, <code>Packages.gz</code>, <code>Contents</code>, certificates, and pool files from Debian-style URLs."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="git-compare-arrows"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Upstream mirror ingestion"]</h4>
                        <p class="fs-lg">@Localizer["Track upstream suites and components as metadata snapshots, then compose downstream repositories from those mirror buckets."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="package-plus"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Local package overrides"]</h4>
                        <p class="fs-lg">@Localizer["Upload <code>.deb</code> packages that replace upstream entries by package name and architecture in the final published bucket."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="shield-check"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Atomic snapshot promotion"]</h4>
                        <p class="fs-lg">@Localizer["APT clients only read primary buckets. Incomplete syncs, unsigned metadata, and staging buckets stay invisible."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="key-round"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Certificate management"]</h4>
                        <p class="fs-lg">@Localizer["Generate and manage GPG signing certificates, then expose public keys through repository-friendly artifact routes."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="users"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["RBAC and API keys"]</h4>
                        <p class="fs-lg">@Localizer["Use local accounts or OIDC, grant repository permissions, and publish from CI with scoped API keys."]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="immersive-section apkg-immersive position-relative w-100 overflow-hidden d-flex align-items-center">
    <div class="container position-relative z-2 py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 col-md-12">
                <div class="text-start pe-lg-4">
                    <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
                        <span class="text-info me-2"><i class="fas fa-layer-group"></i></span>
                        <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">@Localizer["Snapshot Pipeline"]</span>
                    </div>
                    <h2 class="display-4 fw-bold text-white mb-3">
                        <span class="text-primary">@Localizer["Build safely."]</span><br>
                        @Localizer["Publish atomically."]
                    </h2>
                    <p class="lead text-gray-400 fs-5">
                        @Localizer["Mirror sync, repository composition, signing, export, and garbage collection are split into independent jobs. Published clients keep reading the last signed primary bucket while new metadata is being prepared."]
                    </p>
                </div>
            </div>
            <div class="col-lg-6 col-md-12">
                <div class="apkg-pipeline">
                    <div class="apkg-pipeline-item">
                        <i data-lucide="download-cloud"></i>
                        <strong>MirrorSyncJob</strong>
                        <span>@Localizer["Pull upstream metadata into mirror buckets."]</span>
                    </div>
                    <div class="apkg-pipeline-item">
                        <i data-lucide="replace"></i>
                        <strong>RepositorySyncJob</strong>
                        <span>@Localizer["Copy mirror data, apply package overrides, and build release metadata."]</span>
                    </div>
                    <div class="apkg-pipeline-item">
                        <i data-lucide="badge-check"></i>
                        <strong>RepositorySignJob</strong>
                        <span>@Localizer["Sign pending buckets and promote them to primary."]</span>
                    </div>
                    <div class="apkg-pipeline-item">
                        <i data-lucide="archive"></i>
                        <strong>RepositoryExportJob</strong>
                        <span>@Localizer["Materialize static artifacts for nginx, caddy, rsync, or edge distribution."]</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="apkg-enterprise py-6 border-top border-white-10">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-lg-8 text-center">
                <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
                    <span class="text-primary me-2"><i data-lucide="building-2" style="width:14px;height:14px;"></i></span>
                    <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">@Localizer["Enterprise Ready"]</span>
                </div>
                <h2 class="h1 text-white mb-3">@Localizer["Ship Debian packages at scale."]</h2>
                <p class="text-gray-400 fs-lg mx-auto mb-0" style="max-width: 700px;">
                    @Localizer["Apkg brings the full APT repository lifecycle into one server — mirror upstream archives, override packages locally, sign and promote atomically, then serve to client machines worldwide."]
                </p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="apkg-enterprise-card bg-dark-glass rounded-3 p-4 h-100 border border-white-10 hover-glow-primary">
                    <div class="apkg-enterprise-icon bg-primary bg-opacity-10 text-primary mb-3">
                        <i data-lucide="package-open" style="width:24px;height:24px;"></i>
                    </div>
                    <h4 class="h5 text-white mb-2">@Localizer["Simplify your distribution"]</h4>
                    <p class="text-gray-400 mb-0 small">
                        @Localizer["Describe packages once in a declarative <code>.aosproj</code> file. No fragile post-install scripts, no per-distro boilerplate — just files, folders, dependencies, and services."]
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="apkg-enterprise-card bg-dark-glass rounded-3 p-4 h-100 border border-white-10 hover-glow-success">
                    <div class="apkg-enterprise-icon bg-success bg-opacity-10 text-success mb-3">
                        <i data-lucide="server" style="width:24px;height:24px;"></i>
                    </div>
                    <h4 class="h5 text-white mb-2">@Localizer["Built on AnduinOS"]</h4>
                    <p class="text-gray-400 mb-0 small">
                        @Localizer["Production-hardened on the same infrastructure that powers AnduinOS package delivery. Battle-tested mirror ingestion, signing pipelines, and atomic snapshot promotion."]
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="apkg-enterprise-card bg-dark-glass rounded-3 p-4 h-100 border border-white-10 hover-glow-warning">
                    <div class="apkg-enterprise-icon bg-warning bg-opacity-10 text-warning mb-3">
                        <i data-lucide="file-code" style="width:24px;height:24px;"></i>
                    </div>
                    <h4 class="h5 text-white mb-2">@Localizer["MSBuild-style syntax"]</h4>
                    <p class="text-gray-400 mb-0 small">
                        @Localizer["If you have written a <code>.csproj</code> you already know <code>.aosproj</code>. XML-based, toolable, and integrated with the Apkg CLI for linting, building, and publishing."]
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="apkg-enterprise-card bg-dark-glass rounded-3 p-4 h-100 border border-white-10 hover-glow-info">
                    <div class="apkg-enterprise-icon bg-info bg-opacity-10 text-info mb-3">
                        <i data-lucide="globe" style="width:24px;height:24px;"></i>
                    </div>
                    <h4 class="h5 text-white mb-2">@Localizer["Global Debian delivery"]</h4>
                    <p class="text-gray-400 mb-0 small">
                        @Localizer["Export static artifacts for nginx, caddy, or rsync to edge nodes. APT clients anywhere get <code>apt update && apt install</code> — no proprietary agents, no custom tooling."]
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="apkg-compare py-6 border-top border-white-10">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-lg-8 text-center">
                <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
                    <span class="text-info me-2"><i data-lucide="git-compare-arrows" style="width:14px;height:14px;"></i></span>
                    <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">@Localizer["Architecture Philosophy"]</span>
                </div>
                <h2 class="h1 text-white mb-3">Apkg vs Dak: <span class="text-primary">@Localizer["Two Ways to Run a Repository"]</span></h2>
                <p class="text-gray-400 fs-lg mx-auto mb-0" style="max-width: 640px;">
                    @Localizer["Debian's <code>Dak</code> has served the community for decades. Apkg takes a different path — shaped by modern CI/CD, cloud infrastructure, and declarative tooling. Both have strengths. Both have trade-offs."]
                </p>
            </div>
        </div>

        <div class="row g-4">
            <!-- Packaging -->
            <div class="col-lg-6">
                <div class="apkg-compare-card">
                    <div class="apkg-compare-header">
                        <i data-lucide="package-open"></i> @Localizer["Packaging"]
                    </div>
                    <div class="row g-0">
                        <div class="col-6 apkg-compare-side apkg-compare-dak">
                            <span class="apkg-compare-label">Dak</span>
                            <p>@Localizer["Imperative <code>debian/rules</code> and dh macros. Mastering Debian packaging takes months of learning arcane shell scripts."]</p>
                        </div>
                        <div class="col-6 apkg-compare-side apkg-compare-apkg">
                            <span class="apkg-compare-label">Apkg</span>
                            <p>@Localizer["Declarative <code>.aosproj</code> files with MSBuild syntax. Files, deps, and scripts in one manifest — if you know <code>.csproj</code>, you know packaging."]</p>
                        </div>
                    </div>
                    <div class="apkg-compare-verdict verdict-wins">
                        <strong>@Localizer["Where Apkg shines:"]</strong> @Localizer["Turns packaging from a black art into standard software engineering."]
                    </div>
                </div>
            </div>

            <!-- Build & Pipeline (merged) -->
            <div class="col-lg-6">
                <div class="apkg-compare-card">
                    <div class="apkg-compare-header">
                        <i data-lucide="refresh-cw"></i> @Localizer["Build & Pipeline"]
                    </div>
                    <div class="row g-0">
                        <div class="col-6 apkg-compare-side apkg-compare-dak">
                            <span class="apkg-compare-label">Dak</span>
                            <p>@Localizer["<code>Buildd</code> farm compiles natively on real hardware. Cron-driven <code>apt-ftparchive</code> regenerates indexes — packages wait hours in <code>incoming</code> before publication."]</p>
                        </div>
                        <div class="col-6 apkg-compare-side apkg-compare-apkg">
                            <span class="apkg-compare-label">Apkg</span>
                            <p>@Localizer["CI cross-compilation with per-arch <code>Condition</code> attributes. Real-time atomic pipeline — sync, sign, swap via <code>rename(2)</code>. Clients never see half-written metadata."]</p>
                        </div>
                    </div>
                    <div class="apkg-compare-verdict verdict-humble">
                        <strong>@Localizer["Room to grow:"]</strong> @Localizer["CI cross-compilation excels on amd64/arm64, but Debian's native Buildd catches architecture-specific UB that cross-toolchains miss."]
                    </div>
                </div>
            </div>

            <!-- Distribution -->
            <div class="col-lg-6">
                <div class="apkg-compare-card">
                    <div class="apkg-compare-header">
                        <i data-lucide="globe"></i> @Localizer["Distribution"]
                    </div>
                    <div class="row g-0">
                        <div class="col-6 apkg-compare-side apkg-compare-dak">
                            <span class="apkg-compare-label">Dak</span>
                            <p>@Localizer["Tiered rsync cascade (T1 → T2) run by volunteers. Decentralized and resilient, but latency varies and DDoS defense depends on each operator."]</p>
                        </div>
                        <div class="col-6 apkg-compare-side apkg-compare-apkg">
                            <span class="apkg-compare-label">Apkg</span>
                            <p>@Localizer["Static export with atomic swap + CDN edge caching + Geo-steering. Shared-nothing edge nodes with built-in WAF before origin."]</p>
                        </div>
                    </div>
                    <div class="apkg-compare-verdict verdict-wins">
                        <strong>@Localizer["Where Apkg shines:"]</strong> @Localizer["Cloud-native CDN delivers consistent low-latency worldwide. DDoS absorbed at the edge."]
                    </div>
                </div>
            </div>

            <!-- Security -->
            <div class="col-lg-6">
                <div class="apkg-compare-card">
                    <div class="apkg-compare-header">
                        <i data-lucide="shield-check"></i> @Localizer["Security & Trust"]
                    </div>
                    <div class="row g-0">
                        <div class="col-6 apkg-compare-side apkg-compare-dak">
                            <span class="apkg-compare-label">Dak</span>
                            <p>@Localizer["GPG Web of Trust with in-person Key Signing Parties. Trust is fully decentralized — no single authority controls the keyring."]</p>
                        </div>
                        <div class="col-6 apkg-compare-side apkg-compare-apkg">
                            <span class="apkg-compare-label">Apkg</span>
                            <p>@Localizer["OIDC-backed RBAC with scoped API keys. Teams authenticate via existing SSO, grant per-repo permissions, and revoke access instantly."]</p>
                        </div>
                    </div>
                    <div class="apkg-compare-verdict verdict-humble">
                        <strong>@Localizer["Room to grow:"]</strong> @Localizer["RBAC is ideal for organizations, but Debian's decentralized WoT remains the gold standard for a trustless global maintainer network."]
                    </div>
                </div>
            </div>

            <!-- Bottom note -->
            <div class="col-12">
                <div class="apkg-compare-card text-center py-4">
                    <p class="text-gray-400 mb-0" style="max-width: 640px; margin: 0 auto;">
                        @Localizer["<strong class=\"text-white\">Dak</strong> is battle-tested infrastructure that has delivered Debian to millions for over two decades. <strong class=\"text-primary\">Apkg</strong> does not aim to replace it — it trades some of that generality for a modern, CI-native, cloud-deployable APT repository that a small team can operate."]
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["The Philosophy"]</span>
            <h2 class="h1">@Localizer["From the Architect"]</h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <blockquote class="apkg-quote card border shadow-sm">
                    <div class="card-body p-5 text-center">
                        <div class="mb-4">
                            <a href="https://anduin.aiursoft.com/" target="_blank" rel="noopener">
                                <img src="https://anduin.aiursoft.com/avatar" width="80" height="80" alt="Anduin Xue" loading="lazy" class="rounded-circle border border-3 border-white shadow-sm">
                            </a>
                        </div>
                        <p class="lead mb-4 fst-italic text-muted">
                            @Localizer["\"Traditional Debian packaging scatters package definition across half a dozen files — <code>control</code>, <code>rules</code>, <code>install</code>, <code>changelog</code>, <code>compat</code> — each in its own arcane dialect. I designed <code>.aosproj</code> to replace all of that with a single declarative manifest. Structured XML makes dependency graphs trivially parseable by both humans and CI machines. CI pipelines collapse to <code>apkg publish &amp;&amp; apkg push</code>. It turns Linux distribution packaging from a black art into standard software engineering.\""]
                        </p>
                        <div>
                            <h5 class="mb-1 fw-bold">Anduin Xue</h5>
                            <small class="d-block text-primary fw-medium">@Localizer["Founder &amp; Architect at Aiursoft"]</small>
                        </div>
                    </div>
                </blockquote>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">@Localizer["Publishing workflow"]</span>
            <h2 class="h1">@Localizer["From <code>.aosproj</code> to <code>apt install</code>."]</h2>
            <p class="text-muted fs-lg mx-auto mb-0" style="max-width: 760px;">
                @Localizer["Developers describe package contents once, build Debian artifacts locally or in CI, push a <code>.apkg</code> bundle, and let the server route packages into the right repositories."]
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">1</div>
                        <h3 class="h5">@Localizer["Create"]</h3>
                        <p class="text-muted mb-0">@Localizer["Start a package project with <code>.aosproj</code>, then declare files, folders, scripts, dependencies, services, suites, and architectures."]</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">2</div>
                        <h3 class="h5">@Localizer["Build"]</h3>
                        <p class="text-muted mb-0">@Localizer["Generate <code>.deb</code> packages with Debian control metadata and maintainer scripts produced from the project file."]</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">3</div>
                        <h3 class="h5">@Localizer["Push"]</h3>
                        <p class="text-muted mb-0">@Localizer["Pack <code>.deb</code> files into a <code>.apkg</code> archive and upload it with an API key from a developer shell or CI pipeline."]</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">4</div>
                        <h3 class="h5">@Localizer["Install"]</h3>
                        <p class="text-muted mb-0">@Localizer["After sync and signing, machines consume the repository with normal APT source files and <code>apt install</code> commands."]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-body-tertiary border-top" id="quick-start">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">@Localizer["CLI quick start"]</span>
                <h2 class="h1 mb-3">@Localizer["Publish from any machine with the .NET tool."]</h2>
                <p class="text-muted fs-lg mb-4">
                    @Localizer["The Apkg CLI handles project creation, linting, package builds, bundle publishing, server uploads, local unpacking, and APT source configuration."]
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-light text-dark border">new</span>
                    <span class="badge bg-light text-dark border">add</span>
                    <span class="badge bg-light text-dark border">lint</span>
                    <span class="badge bg-light text-dark border">build</span>
                    <span class="badge bg-light text-dark border">publish</span>
                    <span class="badge bg-light text-dark border">push</span>
                    <span class="badge bg-light text-dark border">add-source</span>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card bg-dark text-white border-0 shadow">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <i data-lucide="terminal" class="text-primary me-2"></i>
                            <h5 class="mb-0 fw-bold">@Localizer["Command line flow"]</h5>
                        </div>
                        <pre class="apkg-terminal"><code>dotnet tool install --global Aiursoft.Apkg.Client

apkg new --name my-package
apkg lint --path ./my-package
apkg publish --path ./my-package
apkg push ./my-package/bin/my-package.apkg \
  --source https://apkg.example.com \
  --api-key &lt;your-api-key&gt;

sudo apkg add-source https://apkg.example.com/api/sources/1
sudo apt update
sudo apt install my-package</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-dark text-white">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">@Localizer["Web Operations"]</span>
                <h2 class="h1 text-white mb-3">@Localizer["Operate it from the browser."]</h2>
                <p class="text-white-50 fs-lg mb-0">
                    @Localizer["Administrators can manage repositories, upstream mirrors, signing certificates, API keys, package upload history, background jobs, permissions, users, and global settings from the web UI."]
                </p>
            </div>
            <div class="col-lg-5 text-lg-end">
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg btn-pill me-2 mb-2">
                    <i class="align-middle me-1" data-lucide="search"></i>
                    @Localizer["Browse packages"]
                </a>
                <a asp-controller="Jobs" asp-action="Index" class="btn btn-outline-primary btn-lg btn-pill mb-2">
                    <i class="align-middle me-1" data-lucide="clock-3"></i>
                    @Localizer["View jobs"]
                </a>
            </div>
        </div>
    </div>
</section>

