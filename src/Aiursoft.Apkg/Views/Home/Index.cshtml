@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/styles/site.css" xmlns="http://www.w3.org/1999/html"/>
    <link rel="stylesheet" href="~/styles/marketing.css" xmlns="http://www.w3.org/1999/html"/>
}

<vc:marketing-navbar></vc:marketing-navbar>

<section class="apkg-hero text-bg-dark">
    <img src="~/images/screenshot.png" alt="Apkg dashboard showing package repository management" class="apkg-hero-image"/>
    <div class="apkg-hero-shade"></div>
    <div class="container apkg-hero-content">
        <div class="row">
            <div class="col-lg-9 col-xl-8">
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="badge badge-subtle-primary p-2">APT repository server</span>
                    <span class="badge badge-subtle-primary p-2">.apkg publishing</span>
                    <span class="badge badge-subtle-primary p-2">AnduinOS ready</span>
                </div>
                <h1 class="display-2 fw-bold text-white mb-4">Apkg</h1>
                <p class="lead text-white-50 mb-4">
                    Host signed Debian package repositories, mirror upstream Ubuntu archives, and publish distribution-specific package overrides without asking client machines to run fragile post-install scripts.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg btn-pill">
                        <i class="align-middle me-1" data-lucide="layout-dashboard"></i>
                        Enter Dashboard
                    </a>
                    <a href="#quick-start" class="btn btn-outline-light btn-lg btn-pill">
                        <i class="align-middle me-1" data-lucide="terminal"></i>
                        Start Publishing
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary border-bottom">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="apkg-metric">
                    <div class="apkg-metric-value">APT</div>
                    <div class="apkg-metric-label">Standard Debian repository endpoints for <code>apt update</code>, <code>apt install</code>, GPG keys, package indexes, and pool downloads.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="apkg-metric">
                    <div class="apkg-metric-value">.apkg</div>
                    <div class="apkg-metric-label">Portable publishing bundles that contain a manifest plus one or more <code>.deb</code> files for multiple suites and architectures.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="apkg-metric">
                    <div class="apkg-metric-value">Buckets</div>
                    <div class="apkg-metric-label">Immutable repository snapshots that are signed, promoted atomically, and garbage-collected only after references disappear.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="row align-items-start g-5">
            <div class="col-lg-5">
                <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">What Apkg is for</span>
                <h2 class="h1 mb-3">A release platform for Debian-based distributions.</h2>
                <p class="fs-lg text-muted mb-4">
                    Apkg sits between an upstream APT archive and your machines. It mirrors package metadata, applies your local package overrides, signs the final repository, and serves clients through ordinary APT protocol paths.
                </p>
                <a asp-controller="Repositories" asp-action="Index" class="btn btn-outline-primary btn-pill">
                    <i class="align-middle me-1" data-lucide="folder-git-2"></i>
                    View repositories
                </a>
            </div>
            <div class="col-lg-7">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="apkg-feature">
                            <div class="landing-feature"><i data-lucide="server"></i></div>
                            <h3 class="h4">Host signed APT repositories</h3>
                            <p class="text-muted mb-0">Serve <code>InRelease</code>, <code>Release</code>, <code>Packages.gz</code>, <code>Contents</code>, certificate files, and <code>.deb</code> binaries from standard Debian-style URLs.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="apkg-feature">
                            <div class="landing-feature"><i data-lucide="git-compare-arrows"></i></div>
                            <h3 class="h4">Mirror upstream archives</h3>
                            <p class="text-muted mb-0">Track upstream Ubuntu suites and components as metadata snapshots, then compose your own downstream repositories from them.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="apkg-feature">
                            <div class="landing-feature"><i data-lucide="package-plus"></i></div>
                            <h3 class="h4">Publish package overrides</h3>
                            <p class="text-muted mb-0">Upload local `.deb` packages that replace upstream packages by package name and architecture in the final published bucket.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="apkg-feature">
                            <div class="landing-feature"><i data-lucide="shield-check"></i></div>
                            <h3 class="h4">Keep clients on safe snapshots</h3>
                            <p class="text-muted mb-0">APT clients only read primary buckets. Incomplete syncs, unsigned metadata, and build staging buckets stay invisible.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-body-tertiary">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">Publishing workflow</span>
            <h2 class="h1">From <code>.aosproj</code> to <code>apt install</code>.</h2>
            <p class="text-muted fs-lg mx-auto mb-0" style="max-width: 760px;">
                Developers describe package contents once, build Debian artifacts locally or in CI, push a <code>.apkg</code> bundle, and let the server route packages into the right repositories.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">1</div>
                        <h3 class="h5">Create</h3>
                        <p class="text-muted mb-0">Start a package project with <code>.aosproj</code>, then declare files, folders, scripts, dependencies, services, suites, and architectures.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">2</div>
                        <h3 class="h5">Build</h3>
                        <p class="text-muted mb-0">Generate <code>.deb</code> packages with Debian control metadata and maintainer scripts produced from the project file.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">3</div>
                        <h3 class="h5">Push</h3>
                        <p class="text-muted mb-0">Pack <code>.deb</code> files into a <code>.apkg</code> archive and upload it with an API key from a developer shell or CI pipeline.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">4</div>
                        <h3 class="h5">Install</h3>
                        <p class="text-muted mb-0">After sync and signing, machines consume the repository with normal APT source files and `apt install` commands.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-dark text-white">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5">
                <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">Repository pipeline</span>
                <h2 class="h1 text-white mb-3">Built around atomic promotion.</h2>
                <p class="text-white-50 fs-lg mb-0">
                    Long-running operations are split into scheduled jobs. Each job can be retried independently, while published clients keep reading the last signed primary snapshot.
                </p>
            </div>
            <div class="col-lg-7">
                <div class="apkg-pipeline">
                    <div class="apkg-pipeline-item">
                        <i data-lucide="download-cloud"></i>
                        <strong>MirrorSyncJob</strong>
                        <span>Pull upstream metadata into mirror buckets.</span>
                    </div>
                    <div class="apkg-pipeline-item">
                        <i data-lucide="replace"></i>
                        <strong>RepositorySyncJob</strong>
                        <span>Copy mirror data, apply local package overrides, and build release metadata.</span>
                    </div>
                    <div class="apkg-pipeline-item">
                        <i data-lucide="badge-check"></i>
                        <strong>RepositorySignJob</strong>
                        <span>Sign secondary buckets and promote them to primary.</span>
                    </div>
                    <div class="apkg-pipeline-item">
                        <i data-lucide="trash-2"></i>
                        <strong>GarbageCollectionJob</strong>
                        <span>Remove orphaned buckets and unreferenced package objects.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6" id="quick-start">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6">
                <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">CLI quick start</span>
                <h2 class="h1 mb-3">Publish from any machine with the .NET tool.</h2>
                <p class="text-muted fs-lg mb-4">
                    The Apkg CLI handles project creation, linting, package builds, bundle publishing, server uploads, local unpacking, and APT source configuration.
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-light text-dark border">new</span>
                    <span class="badge bg-light text-dark border">add</span>
                    <span class="badge bg-light text-dark border">lint</span>
                    <span class="badge bg-light text-dark border">build</span>
                    <span class="badge bg-light text-dark border">publish</span>
                    <span class="badge bg-light text-dark border">push</span>
                    <span class="badge bg-light text-dark border">add-source</span>
                </div>
            </div>
            <div class="col-lg-6">
                <pre class="apkg-terminal"><code>dotnet tool install --global Aiursoft.Apkg.Client \
  --add-source https://nuget.aiursoft.com/v3/index.json

apkg new --name my-package
apkg lint --path ./my-package
apkg publish --path ./my-package
apkg push ./my-package/bin/my-package.apkg \
  --source https://apkg.example.com \
  --api-key &lt;your-api-key&gt;

sudo apkg add-source https://apkg.example.com/api/sources/1
sudo apt update
sudo apt install my-package</code></pre>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-body-tertiary border-top">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <h2 class="h1 mb-3">Operate it from the browser.</h2>
                <p class="text-muted fs-lg mb-0">
                    Administrators can manage repositories, upstream mirrors, signing certificates, API keys, package upload history, background jobs, permissions, users, and global settings from the web UI.
                </p>
            </div>
            <div class="col-lg-5 text-lg-end">
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg btn-pill me-2 mb-2">
                    <i class="align-middle me-1" data-lucide="search"></i>
                    Browse packages
                </a>
                <a asp-controller="Jobs" asp-action="Index" class="btn btn-outline-primary btn-lg btn-pill mb-2">
                    <i class="align-middle me-1" data-lucide="clock-3"></i>
                    View jobs
                </a>
            </div>
        </div>
    </div>
</section>

<vc:marketing-footer></vc:marketing-footer>
