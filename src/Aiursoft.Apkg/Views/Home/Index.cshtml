@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/styles/site.css" xmlns="http://www.w3.org/1999/html"/>
    <link rel="stylesheet" href="~/styles/marketing.css" xmlns="http://www.w3.org/1999/html"/>
}

<vc:marketing-navbar></vc:marketing-navbar>

<section class="apkg-hero landing-intro text-bg-dark pt-5 pt-lg-6 pb-5 pb-lg-7">
    <div class="landing-intro-content container h-100">
        <div class="row align-items-center h-100">
            <div class="col-lg-5 mx-auto">
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="badge badge-subtle-primary p-2">APT repository server</span>
                    <span class="badge badge-subtle-primary p-2">.apkg publishing</span>
                    <span class="badge badge-subtle-primary p-2">AnduinOS ready</span>
                </div>
                <h1 id="main-slogan" class="my-4 text-white" style="font-size: 3rem;">
                    Apkg <span class="text-primary">Repository Platform</span>
                </h1>
                <p class="text-lg text-white-50">
                    Host signed Debian package repositories, mirror upstream Ubuntu archives, and publish distribution-specific package overrides without asking client machines to run fragile post-install scripts.
                </p>
                <form method="get" asp-action="Index" asp-controller="Dashboard" class="apkg-hero-search my-4">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0">
                            <i data-lucide="search" style="width:20px;height:20px;"></i>
                        </span>
                        <input type="text"
                               name="q"
                               maxlength="40"
                               class="form-control border-start-0 ps-0"
                               placeholder="Search packages..."
                               aria-label="Search packages"/>
                        <button class="btn btn-primary px-4" type="submit">Search</button>
                    </div>
                </form>
                <div class="my-4 d-flex flex-wrap gap-3">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="layout-dashboard"></i> Enter Dashboard
                    </a>
                    <a href="#quick-start" class="btn btn-outline-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="terminal"></i> Start Publishing
                    </a>
                    <a href="https://github.com/aiursoftweb/apkg" target="_blank" class="btn btn-outline-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="github"></i> View on GitHub
                    </a>
                </div>
            </div>
            <div class="col-lg-7 d-none d-lg-flex mx-auto text-center">
                <div class="apkg-hero-preview landing-intro-screenshot shadow-lg">
                    <img src="~/images/screenshot.png" alt="Apkg dashboard showing package repository management" class="img-fluid rounded"/>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-body-tertiary border-bottom apkg-stats">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="apkg-metric">
                    <div class="apkg-metric-value">APT</div>
                    <div class="apkg-metric-label">Standard Debian repository endpoints for <code>apt update</code>, <code>apt install</code>, GPG keys, package indexes, and pool downloads.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="apkg-metric">
                    <div class="apkg-metric-value">.apkg</div>
                    <div class="apkg-metric-label">Portable publishing bundles with a manifest plus one or more <code>.deb</code> files for multiple suites and architectures.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="apkg-metric">
                    <div class="apkg-metric-value">Buckets</div>
                    <div class="apkg-metric-label">Immutable repository snapshots that are signed, promoted atomically, and collected only after references disappear.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">Distribution Infrastructure</span>
            <h2 class="h1">Everything needed to publish an APT repository.</h2>
            <p class="text-muted fs-lg mx-auto mb-0" style="max-width: 760px;">
                Apkg sits between upstream archives, package developers, and client machines. It turns mirror metadata and uploaded overrides into signed, stable repository snapshots.
            </p>
        </div>

        <div class="row">
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="server"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">Signed APT hosting</h4>
                        <p class="fs-lg">Serve <code>InRelease</code>, <code>Release</code>, <code>Packages.gz</code>, <code>Contents</code>, certificates, and pool files from Debian-style URLs.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="git-compare-arrows"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">Upstream mirror ingestion</h4>
                        <p class="fs-lg">Track upstream suites and components as metadata snapshots, then compose downstream repositories from those mirror buckets.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="package-plus"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">Local package overrides</h4>
                        <p class="fs-lg">Upload <code>.deb</code> packages that replace upstream entries by package name and architecture in the final published bucket.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="shield-check"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">Atomic snapshot promotion</h4>
                        <p class="fs-lg">APT clients only read primary buckets. Incomplete syncs, unsigned metadata, and staging buckets stay invisible.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="key-round"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">Certificate management</h4>
                        <p class="fs-lg">Generate and manage GPG signing certificates, then expose public keys through repository-friendly artifact routes.</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="users"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">RBAC and API keys</h4>
                        <p class="fs-lg">Use local accounts or OIDC, grant repository permissions, and publish from CI with scoped API keys.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="immersive-section apkg-immersive position-relative w-100 overflow-hidden d-flex align-items-center">
    <div class="container position-relative z-2 py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 col-md-12">
                <div class="text-start pe-lg-4">
                    <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
                        <span class="text-info me-2"><i class="fas fa-layer-group"></i></span>
                        <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">Snapshot Pipeline</span>
                    </div>
                    <h2 class="display-4 fw-bold text-white mb-3">
                        <span class="text-primary">Build safely.</span><br>
                        Publish atomically.
                    </h2>
                    <p class="lead text-gray-400 fs-5">
                        Mirror sync, repository composition, signing, export, and garbage collection are split into independent jobs. Published clients keep reading the last signed primary bucket while new metadata is being prepared.
                    </p>
                </div>
            </div>
            <div class="col-lg-6 col-md-12">
                <div class="apkg-pipeline">
                    <div class="apkg-pipeline-item">
                        <i data-lucide="download-cloud"></i>
                        <strong>MirrorSyncJob</strong>
                        <span>Pull upstream metadata into mirror buckets.</span>
                    </div>
                    <div class="apkg-pipeline-item">
                        <i data-lucide="replace"></i>
                        <strong>RepositorySyncJob</strong>
                        <span>Copy mirror data, apply package overrides, and build release metadata.</span>
                    </div>
                    <div class="apkg-pipeline-item">
                        <i data-lucide="badge-check"></i>
                        <strong>RepositorySignJob</strong>
                        <span>Sign pending buckets and promote them to primary.</span>
                    </div>
                    <div class="apkg-pipeline-item">
                        <i data-lucide="archive"></i>
                        <strong>RepositoryExportJob</strong>
                        <span>Materialize static artifacts for nginx, caddy, rsync, or edge distribution.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">Publishing workflow</span>
            <h2 class="h1">From <code>.aosproj</code> to <code>apt install</code>.</h2>
            <p class="text-muted fs-lg mx-auto mb-0" style="max-width: 760px;">
                Developers describe package contents once, build Debian artifacts locally or in CI, push a <code>.apkg</code> bundle, and let the server route packages into the right repositories.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">1</div>
                        <h3 class="h5">Create</h3>
                        <p class="text-muted mb-0">Start a package project with <code>.aosproj</code>, then declare files, folders, scripts, dependencies, services, suites, and architectures.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">2</div>
                        <h3 class="h5">Build</h3>
                        <p class="text-muted mb-0">Generate <code>.deb</code> packages with Debian control metadata and maintainer scripts produced from the project file.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">3</div>
                        <h3 class="h5">Push</h3>
                        <p class="text-muted mb-0">Pack <code>.deb</code> files into a <code>.apkg</code> archive and upload it with an API key from a developer shell or CI pipeline.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body p-4">
                        <div class="apkg-step">4</div>
                        <h3 class="h5">Install</h3>
                        <p class="text-muted mb-0">After sync and signing, machines consume the repository with normal APT source files and <code>apt install</code> commands.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-body-tertiary border-top" id="quick-start">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">CLI quick start</span>
                <h2 class="h1 mb-3">Publish from any machine with the .NET tool.</h2>
                <p class="text-muted fs-lg mb-4">
                    The Apkg CLI handles project creation, linting, package builds, bundle publishing, server uploads, local unpacking, and APT source configuration.
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-light text-dark border">new</span>
                    <span class="badge bg-light text-dark border">add</span>
                    <span class="badge bg-light text-dark border">lint</span>
                    <span class="badge bg-light text-dark border">build</span>
                    <span class="badge bg-light text-dark border">publish</span>
                    <span class="badge bg-light text-dark border">push</span>
                    <span class="badge bg-light text-dark border">add-source</span>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card bg-dark text-white border-0 shadow">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <i data-lucide="terminal" class="text-primary me-2"></i>
                            <h5 class="mb-0 fw-bold">Command line flow</h5>
                        </div>
                        <pre class="apkg-terminal"><code>dotnet tool install --global Aiursoft.Apkg.Client \
  --add-source https://nuget.aiursoft.com/v3/index.json

apkg new --name my-package
apkg lint --path ./my-package
apkg publish --path ./my-package
apkg push ./my-package/bin/my-package.apkg \
  --source https://apkg.example.com \
  --api-key &lt;your-api-key&gt;

sudo apkg add-source https://apkg.example.com/api/sources/1
sudo apt update
sudo apt install my-package</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-dark text-white">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <span class="text-uppercase text-primary text-sm fw-medium mb-2 d-block">Web Operations</span>
                <h2 class="h1 text-white mb-3">Operate it from the browser.</h2>
                <p class="text-white-50 fs-lg mb-0">
                    Administrators can manage repositories, upstream mirrors, signing certificates, API keys, package upload history, background jobs, permissions, users, and global settings from the web UI.
                </p>
            </div>
            <div class="col-lg-5 text-lg-end">
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg btn-pill me-2 mb-2">
                    <i class="align-middle me-1" data-lucide="search"></i>
                    Browse packages
                </a>
                <a asp-controller="Jobs" asp-action="Index" class="btn btn-outline-primary btn-lg btn-pill mb-2">
                    <i class="align-middle me-1" data-lucide="clock-3"></i>
                    View jobs
                </a>
            </div>
        </div>
    </div>
</section>

<vc:marketing-footer></vc:marketing-footer>
